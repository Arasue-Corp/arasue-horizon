ay_a286beff-module__TPgN-q__variable inter_340cec82-module__dsR-KG__variable\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 w-full backdrop-blur-xl bg-background/95 border-b border-border text-foreground\"><div class=\"bg-primary text-primary-foreground text-xs py-1.5 text-center flex justify-center items-center gap-2 font-semibold tracking-wide\"><span class=\"opacity-80\">An Arasue Horizon Company</span><a class=\"underline hover:opacity-100 transition-opacity\" href=\"/en\">Return to Holding</a></div><div class=\"container mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"py-2\" href=\"/en/labs\"><div class=\"flex items-center gap-2 group \"><div class=\"flex items-center justify-center bg-primary text-primary-foreground rounded-lg transition-transform group-hover:scale-105\" style=\"width:36px;height:36px\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf\" aria-hidden=\"true\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div><div class=\"flex flex-col justify-center\"><span class=\"text-sm font-black tracking-widest uppercase leading-none opacity-50 mb-0.5\">Arasue</span><span class=\"text-xl md:text-2xl font-black font-playfair tracking-tight leading-none text-foreground\">Labs</span></div></div></a><nav class=\"hidden md:flex gap-6 text-sm font-medium\"><a class=\"hover:opacity-70 transition-opacity\" href=\"/en/labs/shop\">Shop</a><a class=\"hover:opacity-70 transition-opacity\" href=\"/en/labs/story\">Our Story</a></nav><div class=\"hidden md:flex items-center gap-4\"><a class=\"flex items-center gap-2 text-xs font-medium hover:opacity-70 transition-opacity\" href=\"/es/labs\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe w-4 h-4\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg> <!-- -->ES</a><a class=\"px-4 py-2 rounded-full bg-primary text-primary-foreground text-sm font-medium active:scale-[0.97] transition-transform duration-200 ease-out flex items-center gap-1\" href=\"/en/labs/contact\">Contact <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></a></div><button class=\"md:hidden p-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main class=\"flex-1\"><div class=\"flex flex-col font-serif bg-background selection:bg-primary selection:text-primary-foreground\"><section class=\"relative h-screen w-full flex flex-col items-center justify-center overflow-hidden\"><div class=\"absolute inset-0 z-0\" style=\"opacity:1;transform:none\"><img src=\"https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?q=80&amp;w=2000&amp;auto=format&amp;fit=crop\" alt=\"Organic Leaves\" class=\"w-full h-full object-cover scale-105\"/><div class=\"absolute inset-0 bg-black/40\"></div></div><div class=\"relative z-10 text-center px-6 flex flex-col items-center\"><div style=\"opacity:0;transform:translateY(20px)\"><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-white/70 block mb-6\">Arasue Labs</span><h1 class=\"text-6xl md:text-8xl lg:text-9xl font-normal tracking-tight leading-[0.9] text-white\">Nature Meets Science</h1></div><p class=\"text-lg md:text-xl mt-12 max-w-xl mx-auto font-sans text-white/80 font-light\" style=\"opacity:0\">Premium organic products, sustainably sourced and meticulously crafted.</p></div></section><section class=\"py-32 md:py-48 px-6 lg:px-24\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24 items-center\"><div class=\"space-y-12\" style=\"opacity:0;transform:translateY(40px)\"><h2 class=\"text-4xl md:text-6xl font-normal leading-[1.1] text-foreground\">&quot;<!-- -->From deep forests to premium extracts. The journey of Arasue Labs.<!-- -->&quot;</h2><div class=\"space-y-6 font-sans text-foreground/70 text-lg font-light leading-relaxed max-w-lg\"><p>We believe that the most potent solutions are already engineered by nature. Our mission is to simply extract them with uncompromising purity.</p><p>Every harvest is limited. Every extraction is deliberate. We do not mass produce; we curate.</p></div><a class=\"inline-flex items-center gap-4 text-sm uppercase tracking-widest font-sans font-bold hover:text-accent transition-colors border-b border-foreground pb-1\" href=\"/en/labs/story\">Read our philosophy <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div><div class=\"aspect-[3/4] relative overflow-hidden\" style=\"opacity:0;transform:scale(0.95)\"><img src=\"https://images.unsplash.com/photo-1615397323389-1065a3637172?q=80&amp;w=1000&amp;auto=format&amp;fit=crop\" alt=\"Laboratory Extracts\" class=\"w-full h-full object-cover\"/></div></div></section><section class=\"py-32 px-6 lg:px-24 bg-foreground text-background\"><div class=\"max-w-7xl mx-auto\"><div class=\"mb-24 flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-background/20 pb-12\"><div><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-background/50 block mb-4\">The Apothecary</span><h2 class=\"text-5xl md:text-7xl font-normal tracking-tight\">Our Collection</h2></div><p class=\"font-sans text-background/60 max-w-sm font-light\">Limited-batch organic harvests. Taste the untouched nature.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24\"><div class=\"group cursor-pointer\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"aspect-[4/5] overflow-hidden mb-8 bg-secondary/10 relative\"><img src=\"https://images.unsplash.com/photo-1587049352847-4d4b127bc04e?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Raw Organic Honey\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-[1.5s] ease-out mix-blend-luminosity hover:mix-blend-normal\"/></div><div class=\"flex justify-between items-start\"><div><h3 class=\"text-3xl font-normal mb-2\">Raw Organic Honey</h3><p class=\"font-sans text-background/60 text-sm font-light max-w-xs\">100% pure, unpasteurized honey sourced directly from our reserves.</p></div><div class=\"text-right\"><p class=\"text-xl\">$45</p><button class=\"mt-2 text-xs font-sans uppercase tracking-widest text-accent hover:text-white transition-colors border-b border-accent/30 pb-0.5\">Add to Cart</button></div></div></div><div class=\"group cursor-pointer md:mt-32\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"aspect-[4/5] overflow-hidden mb-8 bg-secondary/10 relative\"><img src=\"https://images.unsplash.com/photo-1608248593801-5221b4d0879b?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Wellness Extracts\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-[1.5s] ease-out mix-blend-luminosity hover:mix-blend-normal\"/></div><div class=\"flex justify-between items-start\"><div><h3 class=\"text-3xl font-normal mb-2\">Wellness Extracts</h3><p class=\"font-sans text-background/60 text-sm font-light max-w-xs\">Potent organic tinctures and health supplements.</p></div><div class=\"text-right\"><p class=\"text-xl\">$85</p><button class=\"mt-2 text-xs font-sans uppercase tracking-widest text-accent hover:text-white transition-colors border-b border-accent/30 pb-0.5\">Add to Cart</button></div></div></div></div></div></section><section class=\"py-32 px-6 lg:px-24 bg-background border-t border-foreground/10\"><div class=\"max-w-7xl mx-auto flex flex-col items-center text-center\"><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-foreground/50 block mb-12\">Featured In</span><div class=\"grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8 items-center w-full\"><div class=\"space-y-6\"><p class=\"font-serif text-2xl lg:text-3xl text-foreground/90 italic leading-snug\">&quot;The absolute pinnacle of organic purity. Arasue Labs has redefined botanical wellness.&quot;</p><p class=\"font-sans text-xs uppercase tracking-widest font-bold text-accent\">— Vogue Botanical</p></div><div class=\"space-y-6 md:scale-110\"><p class=\"font-serif text-3xl lg:text-4xl text-foreground font-medium italic leading-snug\">&quot;An uncompromising approach to nature. The extracts are simply transcendent.&quot;</p><p class=\"font-sans text-xs uppercase tracking-widest font-bold text-accent\">— GQ Wellness</p></div><div class=\"space-y-6\"><p class=\"font-serif text-2xl lg:text-3xl text-foreground/90 italic leading-snug\">&quot;It feels less like skincare and more like an ancient apothecary secret.&quot;</p><p class=\"font-sans text-xs uppercase tracking-widest font-bold text-accent\">— The Monocle</p></div></div></div></section><section class=\"py-32 px-6 lg:px-24 bg-foreground text-background\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div class=\"order-2 lg:order-1 aspect-square relative overflow-hidden\"><img src=\"https://images.unsplash.com/photo-1598440947619-2c35fc9aa908?q=80&amp;w=800&amp;auto=format&amp;fit=crop\" alt=\"Botanical Setup\" class=\"w-full h-full object-cover mix-blend-luminosity opacity-80\"/></div><div class=\"order-1 lg:order-2 space-y-8 lg:pl-12\"><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-background/50 block\">Personalized Regiment</span><h2 class=\"text-4xl md:text-6xl font-normal leading-tight\">Not sure where to begin your journey?</h2><p class=\"text-lg font-sans text-background/70 font-light leading-relaxed\">Every skin and body is entirely unique. Take our 2-minute botanical assessment to discover the exact extract formulation your body needs right now.</p><button class=\"mt-8 inline-flex items-center gap-4 text-sm uppercase tracking-widest font-sans font-bold text-background border border-background/30 px-8 py-4 hover:bg-background hover:text-foreground transition-all duration-500\">Find Your Extract <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button></div></div></section><section class=\"py-32 px-6 lg:px-24 bg-background\"><div class=\"max-w-4xl mx-auto\"><div class=\"text-center mb-16\"><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-foreground/50 block mb-4\">The Details</span><h2 class=\"text-4xl md:text-6xl font-normal\">Common Inquiries</h2></div><div class=\"space-y-0 border-t border-foreground/10 font-sans\"><div class=\"py-8 border-b border-foreground/10 group cursor-pointer\"><h3 class=\"text-xl font-bold mb-4 group-hover:text-accent transition-colors\">Where do you source your ingredients?</h3><p class=\"text-foreground/70 font-light leading-relaxed\">We partner exclusively with multi-generational organic farms across South America and the Mediterranean. Every harvest is certified organic, ethically sourced, and entirely unrefined to maintain maximum botanical potency.</p></div><div class=\"py-8 border-b border-foreground/10 group cursor-pointer\"><h3 class=\"text-xl font-bold mb-4 group-hover:text-accent transition-colors\">Do you ship internationally?</h3><p class=\"text-foreground/70 font-light leading-relaxed\">Yes. We offer temperature-controlled global shipping to ensure our extracts arrive in pristine condition, regardless of the destination. Typical delivery times range from 3 to 7 business days globally.</p></div><div class=\"py-8 border-b border-foreground/10 group cursor-pointer\"><h3 class=\"text-xl font-bold mb-4 group-hover:text-accent transition-colors\">Are the products vegan and cruelty-free?</h3><p class=\"text-foreground/70 font-light leading-relaxed\">Absolutely. With the sole exception of our ethically-harvested Raw Organic Honey, all formulations are 100% vegan. We strictly prohibit animal testing at every stage of production.</p></div></div></div></section><section class=\"py-32 px-6 bg-background text-foreground text-center border-t border-foreground/10\"><div class=\"max-w-3xl mx-auto space-y-12\"><span class=\"text-xs tracking-[0.3em] uppercase font-sans text-foreground/50 block\">Partnerships</span><h2 class=\"text-5xl md:text-7xl font-normal\">Wholesale &amp; Support</h2><p class=\"text-xl font-sans text-foreground/70 max-w-xl mx-auto font-light\">Reach out for bulk orders and premium partnerships.</p><div class=\"pt-8\"><a class=\"inline-block px-12 py-5 border border-foreground text-foreground hover:bg-foreground hover:text-background transition-colors duration-500 font-sans text-sm uppercase tracking-widest font-bold\" href=\"/en/labs/contact\">Contact Inquiry</a></div></div></section></div><!--$--><!--/$--></main><footer class=\"bg-foreground text-background py-24 px-6 lg:px-24 border-t border-background/20 font-sans\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16\"><div class=\"lg:col-span-2 space-y-8\"><h2 class=\"text-3xl font-serif\">Arasue Labs.</h2><p class=\"text-background/60 max-w-sm font-light\">Get the latest updates from Arasue Horizon.</p><form class=\"flex max-w-md border-b border-background/30 pb-2 focus-within:border-accent transition-colors\"><input type=\"email\" placeholder=\"Your email address\" class=\"bg-transparent w-full outline-none text-background placeholder:text-background/30\"/><button type=\"submit\" class=\"uppercase tracking-widest text-xs font-bold text-accent hover:text-white transition-colors\">Subscribe</button></form></div><div><h4 class=\"text-xs uppercase tracking-widest text-background/50 mb-6\">Quick Links</h4><ul class=\"space-y-4 text-sm font-light text-background/80\"><li><a class=\"hover:text-accent transition-colors\" href=\"/en/labs\">Shop All</a></li><li><a class=\"hover:text-accent transition-colors\" href=\"/en/labs/story\">Our Story</a></li><li><a class=\"hover:text-accent transition-colors\" href=\"/en/labs/contact\">Wholesale</a></li><li><a class=\"hover:text-accent transition-colors\" href=\"/en\">Arasue Horizon</a></li></ul></div><div><h4 class=\"text-xs uppercase tracking-widest text-background/50 mb-6\">Legal</h4><ul class=\"space-y-4 text-sm font-light text-background/80\"><li>123 Innovation Drive, Tech City, Global</li><li>hello@arasue.com</li><li><a class=\"hover:text-accent transition-colors\" href=\"#\">Privacy Policy</a></li><li><a class=\"hover:text-accent transition-colors\" href=\"#\">Terms of Service</a></li></ul></div></div><div class=\"max-w-7xl mx-auto mt-24 pt-8 border-t border-background/10 flex flex-col md:flex-row justify-between items-center text-xs text-background/40 font-light\"><p>© <!-- -->2026<!-- --> Arasue Horizon SAS. <!-- -->All rights reserved.</p><p class=\"mt