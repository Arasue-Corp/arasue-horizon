"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 shrink-0 text-foreground/40\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"font-inter font-medium text-sm\">Compliance &amp; High-Security Infrastructure</span></li><li class=\"flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 shrink-0 text-foreground/40\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"font-inter font-medium text-sm\">Dedicated Engineering Team</span></li><li class=\"flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 shrink-0 text-foreground/40\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"font-inter font-medium text-sm\">24/7 SLA Uptime Guarantee</span></li></ul><a class=\"w-full py-4 rounded-full font-bold text-center transition-transform active:scale-95 bg-foreground text-background hover:bg-foreground/90\" href=\"/en/forge/contact\">Get Started</a></div></div></div><div class=\"container mx-auto px-6 max-w-4xl mt-32\"><h3 class=\"text-4xl font-bold tracking-tighter text-center mb-16\">Frequently Asked Questions</h3><div class=\"space-y-8\"><div class=\"p-8 rounded-3xl bg-secondary/50 border border-border\"><h4 class=\"text-xl font-bold mb-3\">Do you offer custom development outside these plans?</h4><p class=\"text-foreground/70 font-inter\">Yes, we handle enterprise-grade custom applications. Contact us for a custom quote based on your exact specifications.</p></div><div class=\"p-8 rounded-3xl bg-secondary/50 border border-border\"><h4 class=\"text-xl font-bold mb-3\">What technologies do you use?</h4><p class=\"text-foreground/70 font-inter\">We specialize in the React ecosystem (Next.js, React Native), Node.js, PostgreSQL, and robust cloud-native architectures deployed on AWS/Vercel.</p></div><div class=\"p-8 rounded-3xl bg-secondary/50 border border-border\"><h4 class=\"text-xl font-bold mb-3\">How does the SaaS web model work?</h4><p class=\"text-foreground/70 font-inter\">Instead of a massive upfront cost, you pay a smaller setup fee and a monthly subscription that covers high-performance hosting, priority maintenance, and minor updates forever.</p></div></div></div></div><!--$--><!--/$--></main><footer class=\"mt-20 border-t border-foreground/10 bg-background pt-16 pb-8\"><div class=\"container mx-auto px-6\"><div class=\"flex flex-col md:flex-row justify-between items-center gap-8 mb-12\"><div class=\"space-y-4 text-center md:text-left\"><a class=\"group inline-block\" href=\"/en/forge\"><img src=\"/logo-forge.png\" alt=\"Arasue Forge\" class=\"h-14 md:h-16 w-auto object-contain transition-transform group-hover:scale-105\"/></a><p class=\"text-foreground/60 text-sm max-w-sm\">Premium software development and digital strategy agency.</p></div><div class=\"flex gap-6 text-sm font-bold\"><a class=\"hover:text-foreground/70 transition-colors\" href=\"/en/forge#services\">Services</a><a class=\"hover:text-foreground/70 transition-colors\" href=\"/en/forge/contact\">Contact</a><a class=\"hover:text-foreground/70 transition-colors\" href=\"/en\">Arasue Horizon (Holding)</a></div></div><div class=\"pt-8 border-t border-foreground/10 text-center flex flex-col items-center gap-2 text-xs font-semibold text-foreground/40\"><p>© <!-- -->2026<!-- --> Arasue Forge LLC. An Arasue Horizon Company. All rights reserved.</p></div></div></footer><script src=\"/_next/static/chun