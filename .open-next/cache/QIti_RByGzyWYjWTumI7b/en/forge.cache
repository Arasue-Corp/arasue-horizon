-sm font-bold active:scale-[0.97] transition-transform duration-200 ease-out flex items-center gap-1\" href=\"/en/forge/contact\">Contact Us<!-- --> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></a></div><button class=\"md:hidden p-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main class=\"flex-1\"><div class=\"flex flex-col bg-background text-foreground\"><section class=\"relative min-h-screen flex items-center pt-32 pb-24 px-6 bg-background overflow-hidden\"><div class=\"absolute inset-0 z-0 bg-gradient-to-b from-white via-background to-background pointer-events-none\"></div><div class=\"container mx-auto max-w-7xl relative z-10 text-center flex flex-col items-center\" style=\"opacity:0;transform:translateY(40px)\"><div class=\"inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white border border-border shadow-sm text-sm font-medium mb-12 text-foreground/80\"><span class=\"w-2 h-2 rounded-full bg-accent animate-pulse\"></span>Premium Software Engineering</div><h1 class=\"text-7xl md:text-[8rem] lg:text-[10rem] font-bold tracking-tighter leading-[0.85] text-foreground mb-8\"><span class=\"\">Premium<!-- --> </span><span class=\"text-foreground/30\">Software,<!-- --> </span><span class=\"\">Crafted<!-- --> </span><span class=\"text-foreground/30\">to<!-- --> </span><span class=\"\">Perfection<!-- --> </span></h1><p class=\"text-2xl md:text-4xl text-foreground/60 max-w-3xl mt-8 font-medium tracking-tight font-inter\">We transform your boldest ideas into robust, scalable, and beautifully designed digital products.</p><div class=\"pt-16 flex flex-col sm:flex-row gap-6 font-inter items-center justify-center w-full\"><a class=\"group relative px-12 py-6 rounded-full bg-foreground text-background font-bold text-lg hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-foreground/10\" href=\"#services\"><span class=\"relative z-10\">See our Services</span></a><a class=\"px-12 py-6 rounded-full font-bold text-lg hover:bg-black/5 active:scale-95 transition-all text-foreground\" href=\"#work\">View Our Work</a></div></div></section><section class=\"py-16 border-y border-foreground/5 bg-secondary/30 relative overflow-hidden\"><div class=\"container mx-auto px-6 text-center relative z-10\"><p class=\"text-sm font-mono text-foreground/40 mb-8 uppercase tracking-widest\">Powered by industry-leading technologies</p><div class=\"flex justify-center overflow-hidden\"><div class=\"flex gap-16 md:gap-32 items-center min-w-max pr-16 md:pr-32\"><div class=\"flex gap-16 md:gap-32 opacity-40 grayscale hover:grayscale-0 transition-all duration-500\"><img alt=\"React\" loading=\"lazy\" width=\"50\" height=\"50\" decoding=\"async\" data-nimg=\"1\" class=\"h-10 w-auto\" style=\"color:transparent\" srcSet=\"/_next/image?url=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2Fa%2Fa7%2FReact-icon.svg&amp;w=64&amp;q=75 1x, /_next/image?url=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2Fa%2Fa7%2FReact-icon.svg&amp;w=128&amp;q=75 2x\" src=\"/_next/image?url=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2Fa%2Fa7%2FReact-icon.svg&amp;w=128&amp;q=75\"/><img alt=\"Next.js\" loading=\"lazy\" width=\"50\" height=\"50\" decoding=\"async\" data-nimg=\"1\" class=\"h-10 w-auto invert\" style=\"color:transparent\" srcSet=\"/_next/image?url=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2F8%2F8e%2FNextjs-logo.svg&amp;