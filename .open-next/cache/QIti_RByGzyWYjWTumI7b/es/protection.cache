,\"s\":\"$undefined\",\"l\":\"$undefined\",\"p\":\"$undefined\",\"d\":\"$undefined\",\"b\":\"QIti_RByGzyWYjWTumI7b\"}\nf:[]\n9:\"$Wf\"\n10:I[38648,[\"/_next/static/chunks/1dhfmbtzhwjee.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\",\"/_next/static/chunks/2u7ogw365h0rd.js\"],\"ProtectionClient\"]\n5:[\"$\",\"$L10\",null,{\"lang\":\"es\"}]\n11:I[79520,[\"/_next/static/chunks/1dhfmbtzhwjee.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\"],\"\"]\n12:I[21267,[\"/_next/static/chunks/1dhfmbtzhwjee.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\"],\"HeaderProtection\"]\n4:[\"$\",\"html\",null,{\"lang\":\"es\",\"className\":\"theme-protection\",\"suppressHydrationWarning\":true,\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"$L11\",null,{\"src\":\"https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX\",\"strategy\":\"afterInteractive\"}],[\"$\",\"$L11\",null,{\"id\":\"google-analytics\",\"strategy\":\"afterInteractive\",\"children\":\"\\n          window.dataLayer = window.dataLayer || [];\\n          function gtag(){dataLayer.push(arguments);}\\n          gtag('js', new Date());\\n\\n          gtag('config', 'G-XXXXXXXXXX');\\n        \"}],[\"$\",\"$L11\",null,{\"id\":\"microsoft-clarity\",\"strategy\":\"afterInteractive\",\"children\":\"\\n          (function(c,l,a,r,i,t,y){\\n              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};\\n              t=l.createElement(r);t.async=1;t.src=\\\"https://www.clarity.ms/tag/\\\"+i;\\n              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);\\n          })(window, document, \\\"clarity\\\", \\\"script\\\", \\\"xxxxxxxxxx\\\");\\n        \"}]]}],[\"$\",\"body\",null,{\"suppressHydrationWarning\":true,\"className\":\"antialiased min-h-screen flex flex-col bg-background text-foreground playfair_display_a286beff-module__TPgN-q__variable inter_340cec82-module__dsR-KG__variable\",\"children\":[[\"$\",\"$L12\",null,{\"dict\":{\"nav\":{\"horizon\":\"Arasue Horizon\",\"forge\":\"Arasue Forge\",\"workshop\":\"Workshop\",\"language\":\"Idioma\",\"divisions\":\"Divisiones\",\"currency_detected\":\"Moneda\",\"holding_menu\":{\"title\":\"El Corporativo\",\"overview\":\"Visión General\",\"overview_desc\":\"Conoce nuestra misión y visión.\",\"investors\":\"Relación con Inversores\",\"investors_desc\":\"Reportes financieros y noticias.\",\"careers\":\"Carreras\",\"careers_desc\":\"Únete a nuestro equipo global.\",\"newsroom\":\"Sala de Prensa\",\"newsroom_desc\":\"Prensa y Actualizaciones\",\"contact\":\"Sede Global\",\"contact_desc\":\"Consultas globales\"},\"subsidiaries_menu\":{\"forge_desc\":\"Productos digitales y SaaS\",\"media_desc\":\"Contenido y Streaming\",\"labs_desc\":\"Bienes orgánicos premium\"},\"services_menu\":{\"growth\":\"Crecimiento y Anuncios\",\"growth_desc\":\"Estrategias SEO y Meta Ads\"},\"forge_menu\":{\"title\":\"Agencia de Software\",\"services\":\"Servicios\",\"services_desc\":\"Desarrollo de software premium.\",\"portfolio\":\"Portafolio\",\"portfolio_desc\":\"Mira nuestro trabajo reciente.\",\"contact\":\"Contáctanos\",\"contact_desc\":\"Inicia tu próximo proyecto.\"},\"media_menu\":{\"title\":\"Producción Multimedia\"},\"labs_menu\":{\"title\":\"Productos Orgánicos\"}},\"footer\":{\"about\":\"Somos un holding tecnológico dedicado a construir la infraestructura del futuro.\",\"links\":\"Enlaces Rápidos\",\"legal\":\"Legal\",\"privacy\":\"Política de Privacidad\",\"terms\":\"Términos de Servicio\",\"address\":\"Sede Global\",\"address_val\":\"123 Innovation Drive, Tech City, Global\",\"newsletter\":\"Suscríbete a nuestro Boletín\",\"newsletter_desc\":\"Recibe las últimas actualizaciones de Arasue Horizon.\",\"subscribe\":\"Suscribirse\",\"rights\":\"Todos los derechos reservados.\"},\"horizon\":{\"hero\":{\"title\":\"La perspectiva lo cambia todo.\",\"subtitle\":\"El mundo se mueve rápido, pero nosotros miramos más allá. Arasue Horizon es la matriz estratégica que conecta mercados, capitales e industrias globales con una visión clara y de largo alcance. No solo gestionamos el presente; diseñamos el mapa del mañana.\",\"cta\":\"Explora nuestro Ecosistema\",\"secondary_cta\":\"Lee nuestro Manifiesto\",\"explore_portfolio\":\"Explorar Portafolio\"},\"stats\":{\"companies\":\"Divisiones Activas\",\"projects\":\"Proyectos Globales\",\"valuation\":\"Millones en Valor Generado\",\"offices\":\"Oficinas Globales\"},\"vision\":{\"title\":\"Impulsando la Innovación\",\"p1\":\"En Arasue Horizon, creemos en el poder de la excelencia diversificada. Al incubar y escalar subsidiarias especializadas, creamos un ecosistema robusto donde la tecnología, los medios y los bienes convergen.\",\"p2\":\"Nuestro corporativo proporciona dirección estratégica, asignación de capital y recursos compartidos, permitiendo a nuestras divisiones enfocarse puramente en transformar sus respectivos mercados.\",\"link\":\"Conoce nuestra visión\"},\"subsidiaries\":{\"title\":\"Nuestro Ecosistema\",\"investors_link\":\"Ver Relación con Inversores\",\"forge\":{\"name\":\"Arasue Forge\",\"description\":\"Las grandes ideas no sirven de nada si se quedan en el aire. Arasue Forge es el estudio de desarrollo donde el software avanzado y la tecnología crítica cobran vida con precisión, fuerza y un rendimiento impecable. Construimos la infraestructura digital que define industrias.\",\"link\":\"Visitar Forge\",\"tag\":\"Ingeniería con carácter.\"},\"labs\":{\"name\":\"Arasue Labs\",\"description\":\"La verdadera excelencia no acepta atajos. Arasue Labs une el rigor de la ciencia con la pureza de la naturaleza, controlando la importación y logística de productos premium con una trazabilidad absoluta. Calidad inquebrantable, desde el origen hasta tus manos.\",\"link\":\"Visitar Labs\",\"tag\":\"Inalterable desde el origen.\"},\"media\":{\"name\":\"Arasue Media\",\"description\":\"En un mar de ruido constante, nosotros creamos profundidad. Arasue Media produce, edita y distribuye contenido de alta fidelidad que captura la atención y deja una marca real. Historias potentes respaldadas por una ejecución sofisticada.\",\"link\":\"Visitar Media\",\"tag\":\"Contenido con carácter.\"},\"protection\":{\"name\":\"Arasue Protection\",\"description\":\"El éxito real no se deja al azar. Arasue Protection blinda tu vida, tu salud y tu patrimonio con soluciones de aseguramiento de alto nivel y total certeza. Cuidamos de tu legado para que tú puedas enfocarte en seguir construyéndolo.\",\"link\":\"Visitar Protection\",\"tag\":\"Tranquilidad sin condiciones.\"}},\"global\":{\"title\":\"Presencia Global\",\"desc\":\"Operando de manera fluida en toda Norteamérica y el resto del mundo.\"},\"news\":{\"title\":\"Desde la Sala de Prensa\",\"link\":\"Ver Todas las Noticias\",\"tag\":\"Comunicado de Prensa\",\"article_title\":\"Arasue Horizon Anuncia Expansión Estratégica a Nuevos Mercados\",\"article_desc\":\"Lee sobre nuestras últimas adquisiciones estratégicas y cómo se alinean con nuestra visión para el próximo año fiscal.\"},\"leadership\":{\"title\":\"Liderazgo\",\"subtitle\":\"Guiados por operadores con un historial de retornos asimétricos.\",\"josue_role\":\"Director Ejecutivo\",\"josue_desc\":\"Arquitecto del ecosistema Arasue. Se enfoca en la asignación de capital y la visión a largo plazo.\",\"elena_role\":\"Directora de Forge\",\"elena_desc\":\"Ex ingeniera principal en importantes firmas tecnológicas. Lidera la ingeniería de productos y la escala de la plataforma.\",\"marcus_role\":\"Director de Media\",\"marcus_desc\":\"Estratega cultural que ha fabricado múltiples momentos virales globales.\"},\"investor_form\":{\"title\":\"Relaciones con Inversores\",\"subtitle\":\"Solicita acceso a nuestra tesis trimestral y divulgaciones financieras.\",\"name\":\"Nombre Completo\",\"firm\":\"Firma / Organización\",\"email\":\"Correo Corporativo\",\"type\":\"Tipo de Inversor\",\"type_vc\":\"Capital de Riesgo\",\"type_pe\":\"Capital Privado\",\"type_fo\":\"Family Office\",\"type_angel\":\"Ángel / Individual\",\"type_other\":\"Otro\",\"submit\":\"Solicitar Acceso\",\"submitting\":\"Solicitando...\",\"success\":\"Solicitud Recibida. Nuestro equipo revisará y responderá en breve.\"},\"philosophy\":{\"label\":\"Filosofía Operativa\",\"statement_1\":\"No seguimos tendencias.\",\"statement_2\":\"Construimos infraestructura.\",\"statement_3\":\"El capital es solo una herramienta. La excelencia operativa es el resultado.\"},\"global_impact\":{\"title\":\"Impacto Global\",\"subtitle\":\"Arquitectando sistemas a través de fronteras. Desde EE.UU. hacia Latinoamérica y el mundo.\",\"stat_1_val\":\"3\",\"stat_1_lbl\":\"Nodos Centrales\",\"stat_2_val\":\"24/7\",\"stat_2_lbl\":\"Operaciones\",\"stat_3_val\":\"$$0\",\"stat_3_lbl\":\"Fricción\"}},\"forge\":{\"hero\":{\"badge\":\"Ingeniería de Software Premium\",\"title\":\"Software Premium, Creado a la Perfección\",\"subtitle\":\"Transformamos tus ideas más audaces en productos digitales robustos, escalables y con un diseño impecable.\",\"cta\":\"Ver nuestros Servicios\",\"secondary_cta\":\"Ver Nuestro Trabajo\",\"cta_contact\":\"Agendar Llamada\"},\"ticker\":{\"trusted\":\"Impulsados por tecnologías líderes en la industria\"},\"services\":{\"title\":\"Nuestra Experiencia\",\"web_dev\":{\"title\":\"Desarrollo Web\",\"desc\":\"Experiencias web-scrolling a medida y de alto rendimiento.\"},\"brand_web\":{\"title\":\"Web de Marca Personal\",\"desc\":\"De Instagram a Web: Una landing page premium para tu marca.\"},\"meta_ads\":{\"title\":\"Auditoría Meta Ads\",\"desc\":\"Análisis profundo y optimización de tus campañas publicitarias.\"},\"seo_audit\":{\"title\":\"Auditoría SEO\",\"desc\":\"Auditoría técnica y de contenido para dominar los resultados de búsqueda.\"},\"automations\":{\"title\":\"Automatizaciones N8N\",\"desc\":\"Ahorra cientos de horas con automatizaciones de flujo de trabajo personalizadas.\"},\"pm\":{\"title\":\"Gestión de Proyectos\",\"desc\":\"Consultoría independiente y liderazgo de proyectos.\"}},\"work\":{\"title\":\"Trabajo Destacado\",\"subtitle\":\"Construimos arquitecturas escalables e interfaces hermosas que impulsan métricas de negocio reales.\",\"project1_category\":\"Plataforma Fintech\",\"project1_title\":\"Dashboard de Pagos Global\",\"project1_desc\":\"Una revisión completa de un dashboard financiero heredado, migrando a Next.js y Tailwind para mejorar los tiempos de carga en un 400% y la retención de usuarios en un 35%.\",\"project2_category\":\"App de E-Commerce\",\"project2_title\":\"Experiencia Retail Premium\",\"project2_desc\":\"Aplicación de comercio headless con sensación nativa utilizando React Native y la API de Storefront de Shopify. Aumentó las tasas de conversión móvil en más del 120%.\"},\"process\":{\"title\":\"Cómo Trabajamos\",\"subtitle\":\"No solo escribimos código; ingeniamos soluciones diseñadas para escalar desde el primer día.\",\"step1\":\"Descubrimiento y Estrategia\",\"step1_desc\":\"Analizamos las necesidades de tu negocio y elaboramos un plan técnico a medida.\",\"arch_title\":\"Arquitectura y Diseño\",\"arch_desc\":\"Diseñamos arquitecturas de sistemas escalables y una hermosa UI/UX que se alinea con tus objetivos de negocio.\",\"step2\":\"Desarrollo y Entrega\",\"step2_desc\":\"Construcción ágil, pruebas rigurosas y un lanzamiento impecable.\",\"step3\":\"Crecimiento y Soporte\",\"step3_desc\":\"Aseguramos que tu producto escale de manera eficiente.\"},\"pricing\":{\"title\":\"Precios SaaS Transparentes\",\"setup\":\"Inicial\",\"mo\":\"/mes\",\"one_time\":\"Pago Único\",\"retainer\":\"Mensualidad\",\"features\":\"Incluye hosting, actualizaciones y soporte prioritario.\"},\"testimonials\":{\"text1\":\"Arasue Forge transformó toda nuestra infraestructura digital. Su arquitectura nos permitió escalar de 10k a 500k usuarios activos mensuales sin un solo contratiempo.\",\"author1\":\"Sarah Jenkins\",\"role1\":\"CTO, Vertex Analytics\",\"text2\":\"La pura velocidad y calidad de su desarrollo en React no tiene igual. No solo construyen apps, construyen productos que la gente ama usar.\",\"author2\":\"David Chen\",\"role2\":\"Fundador, Elevate\"},\"cta\":{\"title\":\"¿Listo para construir?\",\"subtitle\":\"Deja de comprometer la calidad de tu ingeniería. Asóciate con nosotros y escala tus productos digitales hoy.\",\"note\":\"Respuesta en 24 horas. Sin compromisos.\"},\"faq\":{\"title\":\"Preguntas Frecuentes\",\"q1\":\"¿Ofrecen desarrollo a medida fuera de estos planes?\",\"a1\":\"Sí, manejamos aplicaciones personalizadas a nivel empresarial. Contáctanos para una cotización a medida.\",\"q2\":\"¿Qué tecnologías utilizan?\",\"a2\":\"Nos especializamos en el ecosistema React (Next.js), Node.js y arquitecturas nativas de la nube.\",\"q3\":\"¿Cómo funciona el modelo web SaaS?\",\"a3\":\"En lugar de un costo inicial masivo, pagas una pequeña tarifa de instalación y una suscripción mensual que cubre alojamiento, mantenimiento y actualizaciones menores para siempre.\"},\"services_page\":{\"title\":\"Diseñados para Dominar\",\"subtitle\":\"No solo creamos páginas web. Construimos sistemas escalables que dominan tu mercado.\",\"scarcity\":\"Debido a nuestra alta exigencia de calidad, solo aceptamos 3 nuevos clientes por trimestre.\"},\"portfolio_page\":{\"title\":\"Nuestro Trabajo\",\"subtitle\":\"Casos de estudio de productos digitales escalables.\"},\"pricing_page\":{\"title\":\"Precios Transparentes y Escalables\",\"subtitle\":\"Sin costos ocultos. Infraestructura premium en modelos predecibles.\",\"anchoring_text\":\"Mientras las agencias tradicionales cobran más de $50k USD por adelantado, nuestro modelo SaaS garantiza cero deuda técnica por una fracción del costo.\"},\"contact_page\":{\"title\":\"Inicia tu Construcción\",\"subtitle\":\"Programa una sesión de descubrimiento con nuestros arquitectos senior.\"},\"process_section\":{\"title\":\"Cómo Construimos\",\"subtitle\":\"Un enfoque inflexible hacia la ingeniería.\",\"steps\":[{\"title\":\"Descubrimiento de Arquitectura\",\"desc\":\"Mapeamos los requisitos técnicos precisos, modelos de datos y necesidades de infraestructura.\"},{\"title\":\"Diseño de Sistemas\",\"desc\":\"Creación de esquemas de bases de datos escalables y wireframes de alta fidelidad que convierten.\"},{\"title\":\"Sprints de Ingeniería\",\"desc\":\"Desarrollo rápido y ágil utilizando Next.js y arquitecturas sólidas en la nube.\"},{\"title\":\"Despliegue y Escala\",\"desc\":\"Despliegue sin tiempo de inactividad, QA y optimización continua de rendimiento.\"}]},\"estimator_section\":{\"title\":\"Estimador de Proyectos\",\"subtitle\":\"Obtén una línea base inmediata para tu software a medida o transformación digital.\",\"complexity\":\"Complejidad del Alcance\",\"timeline\":\"Urgencia del Cronograma\",\"min\":\"MVP / Web App\",\"max\":\"Ecosistema Empresarial\",\"options\":[{\"id\":\"relaxed\",\"label\":\"Estándar (3-4 Meses)\"},{\"id\":\"rush\",\"label\":\"Urgente (8-10 Semanas)\"}],\"total\":\"Inversión Estimada\",\"note\":\"*Estimación basada en disponibilidad actual. El alcance final requiere una sesión de descubrimiento.\",\"cta\":\"Solicitar Propuesta Formal\",\"submitting\":\"Solicitando...\",\"success\":\"Propuesta solicitada. Te contactaremos pronto.\",\"emailPrompt\":\"Ingresa tu correo laboral para recibir la propuesta:\"}},\"media\":{\"hero\":{\"title\":\"Dando Forma a la Cultura Digital\",\"subtitle\":\"Arasue Media es una potencia en la creación de contenido, streams y narrativa digital.\",\"cta\":\"Ver lo Más Reciente\",\"cta_contact\":\"Trabaja con Nosotros\"},\"services\":{\"title\":\"Nuestras Capacidades\",\"content\":\"Producción de Contenido\",\"streams\":\"Transmisiones en Vivo\",\"branding\":\"Branding Digital\"},\"work_page\":{\"title\":\"Campañas Destacadas\",\"subtitle\":\"Contenido de alto voltaje que moldea la cultura digital.\"},\"creators_page\":{\"title\":\"Nuestro Talento\",\"subtitle\":\"Nuestra red exclusiva de talento digital y productores.\"},\"contact_page\":{\"title\":\"Colabora con Nosotros\",\"subtitle\":\"¿Listo para volverte viral? Hablemos de estrategia.\"}},\"labs\":{\"hero\":{\"title\":\"La Naturaleza se Une a la Ciencia\",\"subtitle\":\"Productos orgánicos premium, obtenidos de manera sustentable y creados meticulosamente.\",\"cta\":\"Ver Colección\"},\"products\":{\"title\":\"Nuestra Colección\",\"honey\":{\"title\":\"Miel Cruda Orgánica\",\"desc\":\"Miel 100% pura y sin pasteurizar obtenida directamente de nuestras reservas.\"},\"wellness\":{\"title\":\"Extractos de Bienestar\",\"desc\":\"Potentes tinturas orgánicas y suplementos para la salud.\"}},\"shop_page\":{\"title\":\"La Botica\",\"subtitle\":\"Cosechas orgánicas de lote limitado. Prueba la naturaleza intacta.\"},\"story_page\":{\"title\":\"Nuestros Orígenes\",\"subtitle\":\"De bosques profundos a extractos premium. El viaje de Arasue Labs.\"},\"contact_page\":{\"title\":\"Mayoreo y Soporte\",\"subtitle\":\"Contáctanos para pedidos por volumen y asociaciones premium.\"}},\"corporate\":{\"about\":{\"title\":\"Nuestra Misión\",\"content\":\"Arasue Horizon se dedica a construir ecosistemas escalables de software, medios y sustentabilidad.\"},\"investors\":{\"title\":\"Relación con Inversores\",\"content\":\"Accede a nuestros últimos reportes financieros, documentos de gobierno corporativo e información para accionistas.\"},\"newsroom\":{\"title\":\"Sala de Prensa\",\"content\":\"Últimas noticias, comunicados y recursos de medios de Arasue Horizon.\"},\"contact\":{\"title\":\"Cuartel General Global\",\"content\":\"Asóciate con Arasue Horizon. Líneas directas a nuestros equipos de inversión y RP.\",\"form\":{\"name_lbl\":\"Nombre Completo\",\"email_lbl\":\"Correo Corporativo\",\"subject_lbl\":\"Asunto\",\"message_lbl\":\"Mensaje\",\"btn_submit\":\"Enviar Mensaje\",\"btn_submitting\":\"Transmitiendo...\",\"success_title\":\"Transmisión Recibida\",\"success_desc\":\"Nuestro equipo de operaciones revisará tu consulta y responderá en menos de 24 horas.\",\"success_btn\":\"Enviar Otro Mensaje\"},\"info\":{\"hq_title\":\"Nodo Principal\",\"press\":\"Consultas de Prensa\",\"investors\":\"Relaciones con Inversores\"}}}},\"lang\":\"es\"}],\"$L13\",\"$L14\"]}]]}]\n15:I[22016,[\"/_next/static/chunks/1dhfmbtzhwjee.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\"],\"\"]\n:HL[\"/logo-horizon.png\",\"image\"]\n13:[\"$\",\"main\",null,{\"className\":\"flex-grow\",\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}]\n14:[\"$\",\"footer\",null,{\"className\":\"mt-32 border-t border-foreground/10 bg-foreground/5 pt-20 pb-10\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16\",\"children\":[[\"$\",\"div\",null,{\"className\":\"lg:col-span-2 space-y-6\",\"children\":[[\"$\",\"$L15\",null,{\"href\":\"/es\",\"className\":\"group inline-block\",\"children\":[\"$\",\"img\",null,{\"src\":\"/logo-horizon.png\",\"alt\":\"Arasue Horizon\",\"className\":\"h-14 md:h-16 w-auto object-contain transition-transform group-hover:scale-105\"}]}],[\"$\",\"p\",null,{\"className\":\"text-foreground/70 max-w-sm\",\"children\":\"Somos un holding tecnológico dedicado a construir la infraestructura del futuro.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-2\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold\",\"children\":\"Sede Global\"}],[\"$\",\"p\",null,{\"className\":\"text-foreground/60 text-sm\",\"children\":\"123 Innovation Drive, Tech City, Global\"}]]}]]}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"h4\",null,{\"className\":\"font-bold text-lg\",\"children\":\"Enlaces Rápidos\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-3 text-sm text-foreground/70\",\"children\