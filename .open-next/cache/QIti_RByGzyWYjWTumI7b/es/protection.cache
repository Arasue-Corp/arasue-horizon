{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/(protection)/layout,_N_T_/[lang]/(protection)/protection/layout,_N_T_/[lang]/(protection)/protection/page,_N_T_/es/protection"},"segmentPaths":["/_tree","/_full","/$d$lang/!KHByb3RlY3Rpb24p/protection/__PAGE__","/$d$lang/!KHByb3RlY3Rpb24p/protection","/$d$lang/!KHByb3RlY3Rpb24p","/$d$lang","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"es\" class=\"theme-protection\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/2a65768255d6b625-s.p.3u4lli0-axodc.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/83afe278b6a6bb3c-s.p.2bn3s6zvc0dyp.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/logo-horizon.png\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/0j3o4hn_mjlwe.css\" data-precedence=\"next\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/14j_9df84htrw.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/33jtdm1y108jx.js\"/><script src=\"/_next/static/chunks/0paxexg6-m0de.js\" async=\"\"></script><script src=\"/_next/static/chunks/3wcd_xpb1gqws.js\" async=\"\"></script><script src=\"/_next/static/chunks/1mfjqidm5qp0a.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-335qeuyajcwr7.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/1dhfmbtzhwjee.js\" async=\"\"></script><script src=\"/_next/static/chunks/3-x5asrt76ef4.js\" async=\"\"></script><script src=\"/_next/static/chunks/2u7ogw365h0rd.js\" async=\"\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX\" as=\"script\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Arasue Protection | Digital Security</title><meta name=\"description\" content=\"Enterprise-grade cybersecurity and digital protection services.\"/><link rel=\"canonical\" href=\"https://arasue.com/es/protection\"/><link rel=\"alternate\" hrefLang=\"en\" href=\"https://arasue.com/en/protection\"/><link rel=\"alternate\" hrefLang=\"es\" href=\"https://arasue.com/es/protection\"/><meta property=\"og:title\" content=\"Arasue Protection\"/><meta property=\"og:description\" content=\"Enterprise-grade cybersecurity and digital protection services.\"/><meta property=\"og:url\" content=\"https://arasue.com/es/protection\"/><meta property=\"og:site_name\" content=\"Arasue Protection\"/><meta property=\"og:locale\" content=\"es\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Arasue Protection\"/><meta name=\"twitter:description\" content=\"Enterprise-grade cybersecurity and digital protection services.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"antialiased min-h-screen flex flex-col bg-background text-foreground playfair_display_a286beff-module__TPgN-q__variable inter_340cec82-module__dsR-KG__variable\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 w-full backdrop-blur-xl bg-background/95 border-b border-border\"><div class=\"bg-primary text-primary-foreground text-xs py-1.5 text-center flex justify-center items-center gap-2 font-semibold tracking-wide\"><span class=\"opacity-80\">An Arasue Horizon Company</span><a class=\"underline hover:opacity-100 transition-opacity\" href=\"/es\">Return to Holding</a></div><div class=\"container mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"py-2\" href=\"/es/protection\"><div class=\"flex items-center gap-2 group \"><div class=\"flex items-center justify-center bg-primary text-primary-foreground rounded-lg transition-transform group-hover:scale-105\" style=\"width:36px;height:36px\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div class=\"flex flex-col justify-center\"><span class=\"text-sm font-black tracking-widest uppercase leading-none opacity-50 mb-0.5\">Arasue</span><span class=\"text-xl md:text-2xl font-black font-playfair tracking-tight leading-none text-foreground\">Protection</span></div></div></a><nav class=\"hidden md:flex gap-6 text-sm font-bold\"><a class=\"hover:text-foreground/70 transition-colors\" href=\"/es/protection#coverage\"></a><a class=\"hover:text-foreground/70 transition-colors\" href=\"/es/protection#process\"></a><a class=\"hover:text-foreground/70 transition-colors\" href=\"/es/protection#calculator\"></a></nav><div class=\"hidden md:flex items-center gap-4\"><a class=\"flex items-center gap-2 text-xs font-bold hover:opacity-70 transition-opacity\" href=\"/en/protection\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe w-4 h-4\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg> <!-- -->EN</a><a class=\"px-4 py-2 rounded-full bg-slate-900 text-slate-100 text-sm font-bold active:scale-[0.97] transition-transform duration-200 ease-out flex items-center gap-1\" href=\"/es/contact\"> <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></a></div><button class=\"md:hidden p-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></header><main class=\"flex-grow\"><div class=\"flex flex-col font-sans bg-background selection:bg-primary selection:text-primary-foreground\"><section class=\"relative min-h-screen flex items-center justify-center overflow-hidden border-b border-border\"><div class=\"absolute inset-0 z-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]\"></div><div class=\"container relative z-10 mx-auto px-6 pt-32 pb-24 flex flex-col items-center text-center\"><div class=\"flex flex-col items-center\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/20 bg-primary/5 text-xs font-mono uppercase tracking-widest mb-8 text-primary\"><span class=\"w-2 h-2 rounded-full bg-primary animate-pulse\"></span>System Online // Secure</div><h1 class=\"text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter mb-6 text-foreground max-w-5xl\">Resiliencia Digital y Gestión de Riesgos.</h1><p class=\"text-xl text-foreground/60 max-w-2xl mb-12 font-medium\">Protección digital de grado corporativo. Auditamos, intermediamos e implementamos soluciones de ciberseguridad de primer nivel para proteger tus activos críticos desde el perímetro hasta el núcleo.</p><div class=\"flex flex-col sm:flex-row gap-4 w-full sm:w-auto\"><a href=\"#solutions\" class=\"px-8 py-4 bg-foreground text-background font-bold text-sm uppercase tracking-widest hover:bg-foreground/90 active:scale-[0.98] transition-all\">Explorar Soluciones</a><a href=\"#assessment\" class=\"px-8 py-4 bg-background text-foreground font-bold text-sm uppercase tracking-widest border border-border hover:bg-secondary active:scale-[0.98] transition-all\">Ejecutar Auditoría</a></div></div></div></section><section class=\"py-8 bg-secondary/50 border-b border-border overflow-hidden\"><div class=\"container mx-auto px-6\"><p class=\"text-xs font-mono text-center text-foreground/50 uppercase tracking-widest mb-6\">Auditando entornos construidos sobre estándares de la industria</p><div class=\"flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-40 grayscale\"><div class=\"text-xl font-black tracking-tighter\">AWS</div><div class=\"text-xl font-black tracking-tighter\">Azure</div><div class=\"text-xl font-black tracking-tighter\">Google Cloud</div><div class=\"text-xl font-black tracking-tighter\">Cloudflare</div><div class=\"text-xl font-black tracking-tighter\">CrowdStrike</div></div></div></section><section class=\"py-32 px-6 bg-background\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div><h2 class=\"text-sm font-mono text-primary uppercase tracking-widest mb-4\">// Threat Landscape</h2><h3 class=\"text-4xl md:text-5xl font-black tracking-tighter leading-tight mb-8\">La esperanza no es una estrategia de seguridad.</h3><p class=\"text-lg text-foreground/70 leading-relaxed font-medium mb-6\">En los negocios modernos, una brecha cibernética no es un &#x27;si&#x27;, es un &#x27;cuándo&#x27;. Sin una arquitectura Zero-Trust robusta y una póliza de ciberseguro integral, tus operaciones, reputación y balance general están completamente expuestos.</p><p class=\"text-lg text-foreground/70 leading-relaxed font-medium\">No solo vendemos software. Actuamos como tus intermediarios estratégicos de riesgo, asegurando que tengas las defensas y pólizas exactas requeridas para sobrevivir eventos digitales catastróficos.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6 font-mono\"><div class=\"p-8 border border-border bg-secondary/20\"><div class=\"text-4xl font-black text-foreground mb-2\">$4.5M</div><div class=\"text-xs text-foreground/50 uppercase tracking-widest\">Costo prom. de brecha de datos en 2024</div></div><div class=\"p-8 border border-border bg-secondary/20\"><div class=\"text-4xl font-black text-foreground mb-2\">24/7</div><div class=\"text-xs text-foreground/50 uppercase tracking-widest\">Monitoreo automatizado de amenazas</div></div><div class=\"p-8 border border-border bg-secondary/20\"><div class=\"text-4xl font-black text-foreground mb-2\">SOC 2</div><div class=\"text-xs text-foreground/50 uppercase tracking-widest\">Requisito de estándar de cumplimiento</div></div><div class=\"p-8 border border-border bg-secondary/20\"><div class=\"text-4xl font-black text-foreground mb-2\">Zero</div><div class=\"text-xs text-foreground/50 uppercase tracking-widest\">Tolerancia para accesos no verificados</div></div></div></div></section><section id=\"solutions\" class=\"py-32 px-6 bg-secondary/30 border-y border-border\"><div class=\"max-w-7xl mx-auto\"><div class=\"mb-16\"><h2 class=\"text-sm font-mono text-primary uppercase tracking-widest mb-4\">// Capabilities Catalog</h2><h3 class=\"text-4xl md:text-5xl font-black tracking-tighter\">Strategic Protection Modules</h3></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"bg-background border border-border p-10 hover:border-primary/50 transition-colors group flex flex-col h-full\"><div class=\"w-14 h-14 bg-secondary text-foreground flex items-center justify-center mb-8 group-hover:bg-primary group-hover:text-primary-foreground transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check w-7 h-7\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><h4 class=\"text-2xl font-bold mb-4\">Corretaje de Ciberseguros</h4><p class=\"text-foreground/60 text-base leading-relaxed mb-8 flex-grow\">Te conectamos con los mejores suscriptores para proteger tu balance general contra ransomware, brechas de datos e interrupciones del negocio. No enfrentes la extorsión sin respaldo financiero.</p><ul class=\"space-y-3 text-sm font-mono text-foreground/60\"><li>&gt; Liability &amp; Ransomware Coverage</li><li>&gt; Business Continuity Planning</li></ul></div><div class=\"bg-background border border-border p-10 hover:border-primary/50 transition-colors group flex flex-col h-full\"><div class=\"w-14 h-14 bg-secondary text-foreground flex items-center justify-center mb-8 group-hover:bg-primary group-hover:text-primary-foreground transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-database w-7 h-7\" aria-hidden=\"true\"><ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"></ellipse><path d=\"M3 5V19A9 3 0 0 0 21 19V5\"></path><path d=\"M3 12A9 3 0 0 0 21 12\"></path></svg></div><h4 class=\"text-2xl font-bold mb-4\">Privacidad de Datos y Cumplimiento</h4><p class=\"text-foreground/60 text-base leading-relaxed mb-8 flex-grow\">Auditorías integrales para asegurar que tu infraestructura cumpla con normativas globales (GDPR, SOC 2). Te ayudamos a pasar revisiones de seguridad y evitar multas severas.</p><ul class=\"space-y-3 text-sm font-mono text-foreground/60\"><li>&gt; SOC 2 &amp; ISO 27001 Readiness</li><li>&gt; Architecture Gap Analysis</li></ul></div><div class=\"bg-background border border-border p-10 hover:border-primary/50 transition-colors group flex flex-col h-full\"><div class=\"w-14 h-14 bg-secondary text-foreground flex items-center justify-center mb-8 group-hover:bg-primary group-hover:text-primary-foreground transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-crosshair w-7 h-7\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"22\" x2=\"18\" y1=\"12\" y2=\"12\"></line><line x1=\"6\" x2=\"2\" y1=\"12\" y2=\"12\"></line><line x1=\"12\" x2=\"12\" y1=\"6\" y2=\"2\"></line><line x1=\"12\" x2=\"12\" y1=\"22\" y2=\"18\"></line></svg></div><h4 class=\"text-2xl font-bold mb-4\">Red Teaming &amp; Pentesting</h4><p class=\"text-foreground/60 text-base leading-relaxed mb-8 flex-grow\">A través de nuestros partners especializados, simulamos ciberataques reales en tu infraestructura para descubrir vulnerabilidades críticas antes de que los atacantes las exploten.</p><ul class=\"space-y-3 text-sm font-mono text-foreground/60\"><li>&gt; Network &amp; Application Pentesting</li><li>&gt; Social Engineering Simulations</li></ul></div><div class=\"bg-background border border-border p-10 hover:border-primary/50 transition-colors group flex flex-col h-full\"><div class=\"w-14 h-14 bg-secondary text-foreground flex items-center justify-center mb-8 group-hover:bg-primary group-hover:text-primary-foreground transition-colors\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-eye w-7 h-7\" aria-hidden=\"true\"><path d=\"M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div><h4 class=\"text-2xl font-bold mb-4\">Protección Digital Ejecutiva</h4><p class=\"text-foreground/60 text-base leading-relaxed mb-8 flex-grow\">Los CEOs y fundadores son blancos principales. Proveemos monitoreo continuo en la Dark Web, endurecimiento de dispositivos personales y protección contra robo de identidad.</p><ul class=\"space-y-3 text-sm font-mono text-foreground/60\"><li>&gt; Dark Web Monitoring</li><li>&gt; Executive Device Hardening</li></ul></div></div></div></section><section class=\"py-32 px-6 bg-background\"><div class=\"max-w-7xl mx-auto\"><div class=\"mb-16\"><h2 class=\"text-sm font-mono text-primary uppercase tracking-widest mb-4\">// Field Reports</h2><h3 class=\"text-4xl md:text-5xl font-black tracking-tighter\">Real Scenarios. Real Mitigation.</h3></div><div class=\"space-y-8 font-mono\"><div class=\"flex flex-col md:flex-row border border-border overflow-hidden\"><div class=\"bg-foreground text-background p-8 md:w-1/3 flex flex-col justify-center\"><span class=\"text-xs uppercase tracking-widest opacity-50 mb-4\">Case Study A</span><h4 class=\"text-2xl font-black mb-2\">FinTech Series A</h4><p class=\"text-sm opacity-80\">SOC 2 Compliance Roadblocking</p></div><div class=\"bg-secondary/10 p-8 md:w-2/3\"><h5 class=\"font-bold text-lg mb-2\">The Incident</h5><p class=\"text-foreground/70 font-sans mb-6\">A rapidly growing payments startup was blocked from closing a $15M Series A round because enterprise clients demanded strict SOC 2 compliance that their MVP architecture couldn&#x27;t pass.</p><h5 class=\"font-bold text-lg mb-2\">The Mitigation</h5><p class=\"text-foreground/70 font-sans\">We audited their AWS environment, implemented strict IAM controls, and brokered a rapid compliance review. They passed the audit in 45 days and secured the funding.</p></div></div><div class=\"flex flex-col md:flex-row border border-border overflow-hidden\"><div class=\"bg-foreground text-background p-8 md:w-1/3 flex flex-col justify-center\"><span class=\"text-xs uppercase tracking-widest opacity-50 mb-4\">Case Study B</span><h4 class=\"text-2xl font-black mb-2\">Global E-commerce</h4><p class=\"text-sm opacity-80\">Ransomware Extortion</p></div><div class=\"bg-secondary/10 p-8 md:w-2/3\"><h5 class=\"font-bold text-lg mb-2\">The Incident</h5><p class=\"text-foreground/70 font-sans mb-6\">A large retailer suffered a devastating ransomware attack encrypting their core databases, demanding a $2M payout and threatening to leak customer data.</p><h5 class=\"font-bold text-lg mb-2\">The Mitigation</h5><p class=\"text-foreground/70 font-sans\">Because we had previously brokered a comprehensive cyber insurance policy for them, the incident response teams were fully covered. The policy covered the forensic cleanup, legal fees, and operational losses, saving the company from bankruptcy.</p></div></div></div></div></section><section class=\"py-32 px-6 bg-secondary/20 border-t border-border\"><div class=\"max-w-4xl mx-auto\"><div class=\"text-center mb-16\"><h2 class=\"text-sm font-mono text-primary uppercase tracking-widest mb-4\">// Intelligence Briefing</h2><h3 class=\"text-4xl md:text-5xl font-black tracking-tighter\">Frequently Asked Questions</h3></div><div class=\"space-y-0 border-t border-border font-sans\"><div class=\"py-8 border-b border-border\"><h3 class=\"text-xl font-bold mb-4\">Why use Arasue Protection instead of hiring a cybersecurity firm directly?</h3><p class=\"text-foreground/70 leading-relaxed font-medium\">Direct firms sell you their specific software or billing hours. We act as your agnostic risk architects. We assess your unique needs, identify the exact gaps, and then broker the precise insurance policies and technical solutions required, ensuring you don&#x27;t overspend on unnecessary tools.</p></div><div class=\"py-8 border-b border-border\"><h3 class=\"text-xl font-bold mb-4\">Do you execute the penetration tests internally?</h3><p class=\"text-foreground/70 leading-relaxed font-medium\">We believe in separation of duties. We design the security architecture and broker the audits, but we utilize vetted, independent boutique hacking teams to execute the actual penetration tests to ensure completely unbiased reporting.</p></div><div class=\"py-8 border-b border-border\"><h3 class=\"text-xl font-bold mb-4\">How long does a compliance audit (like SOC 2) take?</h3><p class=\"text-foreground/70 leading-relaxed font-medium\">Depending on your current infrastructure, a readiness assessment takes 2-4 weeks. Full remediation and formal auditing can take anywhere from 3 to 6 months.</p></div></div></div></section><section id=\"assessment\" class=\"py-32 px-6 bg-[#0F172A] text-white\"><div class=\"max-w-4xl mx-auto bg-black/40 border border-white/10 rounded-xl overflow-hidden backdrop-blur-xl\"><div class=\"bg-white/5 border-b border-white/10 px-4 py-3 flex items-center gap-2\"><div class=\"w-3 h-3 rounded-full bg-red-500/80\"></div><div class=\"w-3 h-3 rounded-full bg-yellow-500/80\"></div><div class=\"w-3 h-3 rounded-full bg-green-500/80\"></div><span class=\"ml-4 text-xs font-mono text-white/40\">admin@arasue-protection:~</span></div><div class=\"p-8 md:p-12\"><h2 class=\"text-3xl font-black mb-4\">Initialize Risk Assessment</h2><p class=\"text-white/60 font-mono text-sm mb-12 max-w-lg leading-relaxed\">&gt; Secure your digital assets before a breach occurs. Run our preliminary assessment to receive a custom security and infrastructure roadmap.</p><form class=\"space-y-6 font-mono text-sm\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"space-y-2\"><label class=\"text-white/50\">organization_name</label><input type=\"text\" class=\"w-full bg-white/5 border border-white/10 p-3 text-white focus:outline-none focus:border-primary transition-colors\" placeholder=\"Acme Corp\"/></div><div class=\"space-y-2\"><label class=\"text-white/50\">corporate_email</label><input type=\"email\" class=\"w-full bg-white/5 border border-white/10 p-3 text-white focus:outline-none focus:border-primary transition-colors\" placeholder=\"cto@acmecorp.com\"/></div></div><div class=\"space-y-2\"><label class=\"text-white/50\">primary_concern</label><select class=\"w-full bg-white/5 border border-white/10 p-3 text-white focus:outline-none focus:border-primary transition-colors appearance-none\"><option class=\"bg-slate-900\">Cyber Insurance Policy</option><option class=\"bg-slate-900\">Compliance Audit (SOC 2 / GDPR)</option><option class=\"bg-slate-900\">Infrastructure Hardening</option><option class=\"bg-slate-900\">General Security Assessment</option></select></div><div class=\"pt-6\"><button type=\"button\" class=\"w-full md:w-auto px-8 py-4 bg-primary text-primary-foreground font-bold uppercase tracking-widest hover:bg-primary/90 transition-colors flex items-center justify-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lock w-4 h-4\" aria-hidden=\"true\"><rect width=\"18\" height=\"11\" x=\"3\" y=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg>Execute Query</button></div></form></div></div></section></div><!--$--><!--/$--></main><footer class=\"mt-32 border-t border-foreground/10 bg-foreground/5 pt-20 pb-10\"><div class=\"container mx-auto px-6\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16\"><div class=\"lg:col-span-2 space-y-6\"><a class=\"group inline-block\" href=\"/es\"><img src=\"/logo-horizon.png\" alt=\"Arasue Horizon\" class=\"h-14 md:h-16 w-auto object-contain transition-transform group-hover:scale-105\"/></a><p class=\"text-foreground/70 max-w-sm\">Somos un holding tecnológico dedicado a construir la infraestructura del futuro.</p><div class=\"space-y-2\"><p class=\"font-bold\">Sede Global</p><p class=\"text-foreground/60 text-sm\">123 Innovation Drive, Tech City, Global</p></div></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">Enlaces Rápidos</h4><ul class=\"space-y-3 text-sm text-foreground/70\"><li><a class=\"hover:text-foreground transition-colors\" href=\"/es\">Arasue Horizon</a></li><li><a class=\"hover:text-foreground transition-colors\" href=\"/es/forge\">Arasue Forge</a></li><li><a class=\"hover:text-foreground transition-colors\" href=\"/es/media\">Arasue Media</a></li><li><a class=\"hover:text-foreground transition-colors\" href=\"/es/labs\">Arasue Labs</a></li><li><a class=\"hover:text-foreground transition-colors\" href=\"/es/protection\">Arasue Protection</a></li><li><a class=\"hover:text-foreground transition-colors\" href=\"/es/workshop\">Workshop</a></li></ul></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">Legal</h4><ul class=\"space-y-3 text-sm text-foreground/70\"><li><a href=\"#\" class=\"hover:text-foreground transition-colors\">Política de Privacidad</a></li><li><a href=\"#\" class=\"hover:text-foreground transition-colors\">Términos de Servicio</a></li></ul></div><div class=\"space-y-4\"><h4 class=\"font-bold text-lg\">Suscríbete a nuestro Boletín</h4><p class=\"text-sm text-foreground/70\">Recibe las últimas actualizaciones de Arasue Horizon.</p><form class=\"flex flex-col gap-2\"><input type=\"email\" placeholder=\"Email\" class=\"px-4 py-2 rounded-xl border border-foreground/20 bg-background focus:outline-none focus:ring-2 focus:ring-foreground/50\"/><button type=\"button\" class=\"px-4 py-2 rounded-xl bg-primary text-primary-foreground font-bold hover:opacity-90 transition-opacity\">Suscribirse</button></form></div></div><div class=\"