sc\":\"Desarrollo rápido y ágil utilizando Next.js y arquitecturas sólidas en la nube.\"},{\"title\":\"Despliegue y Escala\",\"desc\":\"Despliegue sin tiempo de inactividad, QA y optimización continua de rendimiento.\"}]}}],[\"$\",\"$L17\",null,{\"dict\":{\"hero\":\"$5:props:children:0:props:dict\",\"ticker\":{\"trusted\":\"Impulsados por tecnologías líderes en la industria\"},\"services\":{\"title\":\"Nuestra Experiencia\",\"web_dev\":{\"title\":\"Desarrollo Web\",\"desc\":\"Experiencias web-scrolling a medida y de alto rendimiento.\"},\"brand_web\":{\"title\":\"Web de Marca Personal\",\"desc\":\"De Instagram a Web: Una landing page premium para tu marca.\"},\"meta_ads\":{\"title\":\"Auditoría Meta Ads\",\"desc\":\"Análisis profundo y optimización de tus campañas publicitarias.\"},\"seo_audit\":{\"title\":\"Auditoría SEO\",\"desc\":\"Auditoría técnica y de contenido para dominar los resultados de búsqueda.\"},\"automations\":{\"title\":\"Automatizaciones N8N\",\"desc\":\"Ahorra cientos de horas con automatizaciones de flujo de trabajo personalizadas.\"},\"pm\":{\"title\":\"Gestión de Proyectos\",\"desc\":\"Consultoría independiente y liderazgo de proyectos.\"}},\"work\":\"$5:props:children:2:props:dict\",\"process\":{\"title\":\"Cómo Trabajamos\",\"subtitle\":\"No solo escribimos código; ingeniamos soluciones diseñadas para escalar desde el primer día.\",\"step1\":\"Descubrimiento y Estrategia\",\"step1_desc\":\"Analizamos las necesidades de tu negocio y elaboramos un plan técnico a medida.\",\"arch_title\":\"Arquitectura y Diseño\",\"arch_desc\":\"Diseñamos arquitecturas de sistemas escalables y una hermosa UI/UX que se alinea con tus objetivos de negocio.\",\"step2\":\"Desarrollo y Entrega\",\"step2_desc\":\"Construcción ágil, pruebas rigurosas y un lanzamiento impecable.\",\"step3\":\"Crecimiento y Soporte\",\"step3_desc\":\"Aseguramos que tu producto escale de manera eficiente.\"},\"pricing\":{\"title\":\"Precios SaaS Transparentes\",\"setup\":\"Inicial\",\"mo\":\"/mes\",\"one_time\":\"Pago Único\",\"retainer\":\"Mensualidad\",\"features\":\"Incluye hosting, actualizaciones y soporte prioritario.\"},\"testimonials\":{\"text1\":\"Arasue Forge transformó toda nuestra infraestructura digital. Su arquitectura nos permitió escalar de 10k a 500k usuarios activos mensuales sin un solo contratiempo.\",\"author1\":\"Sarah Jenkins\",\"role1\":\"CTO, Vertex Analytics\",\"text2\":\"La pura velocidad y calidad de su desarrollo en React no tiene igual. No solo construyen apps, construyen productos que la gente ama usar.\",\"author2\":\"David Chen\",\"role2\":\"Fundador, Elevate\"},\"cta\":{\"title\":\"¿Listo para construir?\",\"subtitle\":\"Deja de comprometer la calidad de tu ingeniería. Asóciate con nosotros y escala tus productos digitales hoy.\",\"note\":\"Respuesta en 24 horas. Sin compromisos.\"},\"faq\":{\"title\":\"Preguntas Frecuentes\",\"q1\":\"¿Ofrecen desarrollo a medida fuera de estos planes?\",\"a1\":\"Sí, manejamos aplicaciones personalizadas a nivel empresarial. Contáctanos para una cotización a medida.\",\"q2\":\"¿Qué tecnologías utilizan?\",\"a2\":\"Nos especializamos en el ecosistema React (Next.js), Node.js y arquitecturas nativas de la nube.\",\"q3\":\"¿Cómo funciona el modelo web SaaS?\",\"a3\":\"En lugar de un costo inicial masivo, pagas una pequeña tarifa de instalación y una suscripción mensual que cubre alojamiento, mantenimiento y actualizaciones menores para siempre.\"},\"services_page\":{\"title\":\"Diseñados para Dominar\",\"subtitle\":\"No solo creamos páginas web. Construimos sistemas escalables que dominan tu mercado.\",\"scarcity\":\"Debido a nuestra alta exigencia de calidad, solo aceptamos 3 nuevos clientes por trimestre.\"},\"portfolio_page\":{\"title\":\"Nuestro Trabajo\",\"subtitle\":\"Casos de estudio de productos digitales escalables.\"},\"pricing_page\":{\"title\":\"Precios Transparentes y Escalables\",\"subtitle\":\"Sin costos ocultos. Infraestructura premium en modelos predecibles.\",\"anchoring_text\":\"Mientras las agencias tradicionales cobran más de $50k USD por adelantado, nuestro modelo SaaS garantiza cero deuda técnica por una fracción del costo.\"},\"contact_page\":{\"title\":\"Inicia tu Construcción\",\"subtitle\":\"Programa una sesión de descubrimiento con nuestros arquitectos senior.\"},\"process_section\":\"$5:props:children:3:props:dict\",\"estimator_section\":{\"title\":\"Estimador de Proyectos\",\"subtitle\":\"Obtén una línea base inmediata para tu software a medida o transformación digital.\",\"complexity\":\"Complejidad del Alcance\",\"timeline\":\"Urgencia del Cronograma\",\"min\":\"MVP / Web App\",\"max\":\"Ecosistema Empresarial\",\"options\":[{\"id\":\"relaxed\",\"label\":\"Estándar (3-4 Meses)\"},{\"id\":\"rush\",\"label\":\"Urgente (8-10 Semanas)\"}],\"total\":\"Inversión Estimada\",\"note\":\"*Estimación basada en disponibilidad actual. El alcance final requiere una sesión de descubrimiento.\",\"cta\":\"Solicitar Propuesta Formal\",\"submitting\":\"Solicitando...\",\"success\":\"Propuesta solicitada. Te contactaremos pronto.\",\"emailPrompt\":\"Ingresa tu correo laboral para recibir la propuesta:\"}},\"currencySymbol\":\"$$\"}],\"$L18\",\"$L19\",\"$L1a\"]}]\n1b:I[8263,[\"/_next/static/chunks/1h1o0gjrguh6z.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\",\"/_next/static/chunks/2lbe1n4k_veuu.js\"],\"ForgeEstimator\"]\n1c:I[81681,[\"/_next/static/chunks/1h1o0gjrguh6z.js\",\"/_next/static/chunks/3-x5asrt76ef4.js\",\"/_next/static/chunks/2lbe1n4k_veuu.js\"],\"ForgeFAQ\"]\n18:[\"$\",\"section\",null,{\"className\":\"py-32 px-6 bg-secondary/30 relative\",\"children\":[\"$\",\"$L1b\",null,{\"dict\":\"$5:props:children:4:props:dict:estimator_section\",\"currencySymbol\":\"$$\"}]}]\n19:[\"$\",\"section\",null,{\"className\":\"py-32 px-6 bg-background\",\"children\":[\"$\",\"$L1c\",null,{\"dict\":\"$5:props:children:4:props:dict:faq\"}]}]\n1a:[\"$\",\"section\",null,{\"className\":\"py-32 px-6 bg-secondary relative overflow-hidden\",\"childre