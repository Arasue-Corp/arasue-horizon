FGraphQL_Logo.svg&amp;w=128&amp;q=75\"/></div></div></div></div><div class=\"absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-secondary/30 to-transparent z-20 pointer-events-none\"></div><div class=\"absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-secondary/30 to-transparent z-20 pointer-events-none\"></div></section><section id=\"work\" class=\"py-32 px-6 bg-background\"><div class=\"container mx-auto max-w-7xl\"><div class=\"mb-32 text-center\"><h2 class=\"text-6xl md:text-[8rem] font-bold tracking-tighter mb-6 text-foreground\" style=\"opacity:0;transform:translateY(20px)\">Trabajo Destacado</h2><p class=\"text-2xl text-foreground/60 max-w-3xl mx-auto font-inter\" style=\"opacity:0;transform:translateY(20px)\">Construimos arquitecturas escalables e interfaces hermosas que impulsan métricas de negocio reales.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-5xl mx-auto\"><div class=\"relative aspect-square md:aspect-[4/5] w-full flex flex-col items-center justify-center overflow-hidden rounded-3xl group\"><div class=\"absolute inset-0 w-full h-[140%] -top-[20%]\" style=\"transform:translateY(-20%)\"><img alt=\"Portfolio Item\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-700\"></div></div><div class=\"relative z-10 text-center text-white p-6 max-w-sm flex flex-col items-center\" style=\"opacity:0\"><div class=\"text-white/70 font-mono text-xs uppercase tracking-widest mb-3\">Plataforma Fintech</div><h3 class=\"text-3xl md:text-4xl font-black mb-4 tracking-tight leading-tight\">Dashboard de Pagos Global</h3><p class=\"text-sm text-white/80 font-medium mb-6 font-inter leading-relaxed\">Una revisión completa de un dashboard financiero heredado, migrando a Next.js y Tailwind para mejorar los tiempos de carga en un 400% y la retención de usuarios en un 35%.</p><div class=\"flex flex-wrap gap-4 justify-center font-mono\"><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">Next.js</span><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">PostgreSQL</span><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">Stripe API</span></div></div></div><div class=\"relative aspect-square md:aspect-[4/5] w-full flex flex-col items-center justify-center overflow-hidden rounded-3xl group\"><div class=\"absolute inset-0 w-full h-[140%] -top-[20%]\" style=\"transform:translateY(-20%)\"><img alt=\"Portfolio Item\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1522542550221-31fd19575a2d%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/40 group-hover:bg-black/60 transition-colors duration-700\"></div></div><div class=\"relative z-10 text-center text-white p-6 max-w-sm flex flex-col items-center\" style=\"opacity:0\"><div class=\"text-white/70 font-mono text-xs uppercase tracking-widest mb-3\">App de E-Commerce</div><h3 class=\"text-3xl md:text-4xl font-black mb-4 tracking-tight leading-tight\">Experiencia Retail Premium</h3><p class=\"text-sm text-white/80 font-medium mb-6 font-inter leading-relaxed\">Aplicación de comercio headless con sensación nativa utilizando React Native y la API de Storefront de Shopify. Aumentó las tasas de conversión móvil en más del 120%.</p><div class=\"flex flex-wrap gap-4 justify-center font-mono\"><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">React Native</span><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">GraphQL</span><span class=\"px-6 py-3 rounded-full border border-white/20 bg-black/30 backdrop-blur-md text-sm\">Shopify</span></div></div></div></div></div></section><div class=\"relative h-[400vh] bg-secondary\"><div class=\"sticky top-0 h-screen w-full flex items-center overflow-hidden\"><div class=\"container mx-auto max-w-7xl px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 h-full items-center\"><div class=\"space-y-16\"><div><h2 class=\"text-5xl md:text-7xl font-bold tracking-tighter mb-4\">Cómo Construimos</h2><p class=\"text-xl text-foreground/60 font-inter max-w-md\">Un enfoque inflexible hacia la ingeniería.</p></div><div class=\"space-y-12\"><div class=\"flex gap-6\" style=\"opacity:0.3;transform:scale(0.95)\"><div class=\"text-3xl font-mono text-accent font-bold mt-1\">0<!-- -->1</div><div><h3 class=\"text-3xl font-bold mb-3\">Descubrimiento de Arquitectura</h3><p class=\"text-foreground/60 font-inter text-lg max-w-md leading-relaxed\">Mapeamos los requisitos técnicos precisos, modelos de datos y necesidades de infraestructura.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0.3;transform:scale(0.95)\"><div class=\"text-3xl font-mono text-accent font-bold mt-1\">0<!-- -->2</div><div><h3 class=\"text-3xl font-bold mb-3\">Diseño de Sistemas</h3><p class=\"text-foreground/60 font-inter text-lg max-w-md leading-relaxed\">Creación de esquemas de bases de datos escalables y wireframes de alta fidelidad que convierten.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0.3;transform:scale(0.95)\"><div class=\"text-3xl font-mono text-accent font-bold mt-1\">0<!-- -->3</div><div><h3 class=\"text-3xl font-bold mb-3\">Sprints de Ingeniería</h3><p class=\"text-foreground/60 font-inter text-lg max-w-md leading-relaxed\">Desarrollo rápido y ágil utilizando Next.js y arquitecturas sólidas en la nube.</p></div></div><div class=\"flex gap-6\" style=\"opacity:0.3;transform:scale(0.95)\"><div class=\"text-3xl font-mono text-accent font-bold mt-1\">0<!-- -->4</div><div><h3 class=\"text-3xl font-bold mb-3\">Despliegue y Escala</h3><p class=\"text-foreground/60 font-inter text-lg max-w-md leading-relaxed\">Despliegue sin tiempo de inactividad, QA y optimización continua de rendimiento.</p></div></div></div></div><div class=\"hidden lg:block relative h-[70vh] rounded-3xl overflow-hidden shadow-2xl bg-black\"><div class=\"absolute inset-0\" style=\"opacity:1\"><img alt=\"Step 1\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"50vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1517245386807-bb43f82c33c4%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1517245386807-bb43f82c33c4%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1517245386807-bb43f82c33c4%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1517245386807-bb43f82c33c4%3Fq%3