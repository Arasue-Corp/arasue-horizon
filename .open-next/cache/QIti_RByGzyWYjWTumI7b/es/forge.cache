l=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1551288049-bebda4e38f71%3Fq%3D80%26w%3D2070%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-black/5\"></div></div></div></div></div></div><section id=\"services\" class=\"py-32 px-6 relative bg-background\"><div class=\"container mx-auto max-w-7xl\"><div class=\"mb-24 flex flex-col md:flex-row md:justify-between md:items-end gap-8\"><div><h2 class=\"text-6xl md:text-8xl font-black tracking-tighter mb-4 text-foreground\">Precios SaaS Transparentes</h2><p class=\"text-2xl text-foreground/50 font-inter max-w-2xl\">Incluye hosting, actualizaciones y soporte prioritario.</p></div></div><div class=\"relative border-t border-border\"><div class=\"absolute right-0 top-0 w-1/3 h-full hidden lg:block pointer-events-none z-0\"></div><div class=\"relative z-10 lg:w-2/3\"><div class=\"group border-b border-border py-12 cursor-pointer transition-colors hover:bg-black/5 px-8 -mx-8 rounded-3xl\"><div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\"><div class=\"flex-1\"><h3 class=\"text-4xl md:text-5xl font-bold mb-4 text-foreground group-hover:text-accent transition-colors tracking-tight\">Desarrollo Web</h3><p class=\"text-xl text-foreground/60 font-inter max-w-lg leading-relaxed\">Experiencias web-scrolling a medida y de alto rendimiento.</p></div><div class=\"flex flex-row md:flex-col gap-8 md:gap-2 text-left md:text-right\"><div><span class=\"block text-xs font-mono uppercase tracking-widest text-foreground/40 mb-1\">Inicial</span><span class=\"text-2xl font-bold\">$<!-- -->500</span></div><div><span class=\"block text-xs font-mono uppercase tracking-widest text-accent mb-1\">/mes</span><span class=\"text-2xl font-bold\">$<!-- -->150</span></div></div></div></div><div class=\"group border-b border-border py-12 cursor-pointer transition-colors hover:bg-black/5 px-8 -mx-8 rounded-3xl\"><div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\"><div class=\"flex-1\"><h3 class=\"text-4xl md:text-5xl font-bold mb-4 text-foreground group-hover:text-accent transition-colors tracking-tight\">Web de Marca Personal</h3><p class=\"text-xl text-foreground/60 font-inter max-w-lg leading-relaxed\">De Instagram a Web: Una landing page premium para tu marca.</p></div><div class=\"flex flex-row md:flex-col gap-8 md:gap-2 text-left md:text-right\"><div><span class=\"block text-xs font-mono uppercase tracking-widest text-foreground/40 mb-1\">Inicial</span><span class=\"text-2xl font-bold\">$<!-- -->500</span></div><div><span class=\"block text-xs font-mono uppercase tracking-widest text-accent mb-1\">/mes</span><span class=\"text-2xl font-bold\">$<!-- -->150</span></div></div></div></div><div class=\"group border-b border-border py-12 cursor-pointer transition-colors hover:bg-black/5 px-8 -mx-8 rounded-3xl\"><div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\"><div class=\"flex-1\"><h3 class=\"text-4xl md:text-5xl font-bold mb-4 text-foreground group-hover:text-accent transition-colors tracking-tight\">Auditoría Meta Ads</h3><p class=\"text-xl text-foreground/60 font-inter max-w-lg leading-relaxed\">Análisis profundo y optimización de tus campañas publicitarias.</p></div><div class=\"flex flex-row md:flex-col gap-8 md:gap-2 text-left md:text-right\"><div><span class=\"block text-xs font-mono uppercase tracking-widest text-foreground/40 mb-1\">Pago Único</span><span class=\"text-2xl font-bold\">$<!-- -->300</span></div><div><span class=\"block text-xs font-mono uppercase tracking-widest text-accent mb-1\">Mensualidad</span><span class=\"text-2xl font-bold\">$<!-- -->250</span></div></div></div></div><div class=\"group border-b border-border py-12 cursor-pointer transition-colors hover:bg-black/5 px-8 -mx-8 rounded-3xl\"><div class=\"flex flex-col md:flex-row md:items-center justify-between gap-6\"><div class=\"flex-1\"><h3 class=\"text-4xl md:text-5xl font-bold mb-4 text-foreground group-hover:text-accent transition-colors tracking-tight\">Automatizaciones N8N</h3><p class=\"text-xl text-foreground/60 font-inter max-w-lg leading-relaxed\">Ahorra cientos de horas con automatizaciones de flujo de trabajo personalizadas.</p></div><div class=\"flex flex-row md:flex-col gap-8 md:gap-2 text-left md:text-right\"><div><span class=\"block text-xs font-mono uppercase tracking-widest text-foreground/40 mb-1\">Inicial</span><span class=\"text-2xl font-bold\">$<!-- -->800</span></div><div><span class=\"block text-xs font-mono uppercase tracking-widest text-accent mb-1\">/mes</span><span class=\"text-2xl font-bold\">$<!-- -->200</span></div></div></div></div></div></div></div></section><section class=\"py-32 px-6 bg-secondary/30 relative\"><div class=\"bg-white/70 backdrop-blur-3xl border border-white rounded-[2.5rem] overflow-hidden flex flex-col lg:flex-row shadow-[0_30px_60px_rgba(0,0,0,0.05)] max-w-6xl mx-auto\"><div class=\"flex-1 p-8 md:p-16\"><div class=\"mb-16\"><h2 class=\"text-4xl md:text-5xl font-bold mb-4 tracking-tighter\">Estimador de Proyectos</h2><p class=\"text-foreground/60 font-inter text-lg\">Obtén una línea base inmediata para tu software a medida o transformación digital.</p></div><div class=\"space-y-12\"><div><label class=\"font-mono text-xs uppercase tracking-widest text-foreground/50 mb-8 block\">Complejidad del Alcance</label><div class=\"relative pt-1\"><input type=\"range\" min=\"1\" max=\"3\" step=\"1\" class=\"w-full h-3 bg-muted rounded-full appearance-none cursor-pointer hover:bg-muted-foreground/20 transition-all [&amp;::-webkit-slider-thumb]:appearance-none [&amp;::-webkit-slider-thumb]:w-8 [&amp;::-webkit-slider-thumb]:h-8 [&amp;::-webkit-slider-thumb]:bg-foreground [&amp;::-webkit-slider-thumb]:rounded-full [&amp;::-webkit-slider-thumb]:shadow-lg\" value=\"1\"/></div><div class=\"flex justify-between text-xs text-foreground/50 mt-8 font-mono uppercase tracking-widest font-bold\"><span>MVP / Web App</span><span>Ecosistema Empresarial</span></div></div><div><label class=\"font-mono text-xs uppercase tracking-widest text-foreground/50 mb-6 block\">Urgencia del Cronograma</label><div class=\"flex flex-col sm:flex-row gap-4 bg-muted/50 p-2 rounded-3xl\"><button class=\"flex-1 py-5 px-6 rounded-2xl text-sm font-bold font-inter transition-all duration-300 bg-white text-foreground shadow-md\">Estándar (3-4 Meses)</button><button class=\"flex-1 py-5 px-6 rounded-2xl text-sm font-bold font-inter transition-all duration-300 text-foreground/50 hover:bg-white/50\">Urgente (8-10 Semanas)</button></div></div></div></div><div class=\"lg:w-[450px] bg-foreground text-background p-8 md:p-16 flex flex-col justify-center relative overflow-hidden group\"><div class=\"relative z-10\"><h3 class=\"font-mono uppercase tracking-widest text-xs text-background/50 mb-6\">Inversión Estimada</h3><div class=\"mb-6 transition-all duration-300 blur-0 opacity-100 scale-100\"><div class=\"text-4xl md:text-5xl font-black tracking-tighter\">$135,000 - $165,000 MXN</div></div><p class=\"text-background/50 text-sm mb-12 leading-relaxed font-medium font-inter\">*Estimación basada en disponibilidad actual. El alcance final requiere una sesión de descubrimiento.</p><div class=\"space-y-4 font-inter\"><button class=\"w-full bg-white text-foreground font-bold text-base py-5 rounded-2xl hover:bg-neutral-200 active:scale-95 transition-all disabled:opacity-50\">Solicitar Propuesta Formal</button></div></div></div></div></section><section class=\"py-32 px-6 bg-background\"><div class=\"max-w-3xl mx-auto px-6\"><h2 class=\"text-4xl md:text-5xl font-bold tracking-tighter mb-16 text-center text-foreground\">Preguntas Frecuentes</h2><div class=\"space-y-4\"><div class=\"border border-border rounded-2xl bg-secondary/50 overflow-hidden\"><button class=\"w-full flex items-center justify-between p-6 text-left hover:bg-black/5 transition-colors\"><span class=\"font-bold text-lg text-foreground pr-8 tracking-tight\">¿Ofrecen desarrollo a medida fuera de estos planes?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 text-foreground/50 flex-shrink-0 transform transition-transform rotate-180\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button><div class=\"overflow-hidden\" style=\"height:0px;opacity:0\"><div class=\"p-6 pt-0 text-foreground/60 text-base leading-relaxed font-inter\">Sí, manejamos aplicaciones personalizadas a nivel empresarial. Contáctanos para una cotización a medida.</div></div></div><div class=\"border border-border rounded-2xl bg-secondary/50 overflow-hidden\"><button class=\"w-full flex items-center justify-between p-6 text-left hover:bg-black/5 transition-colors\"><span class=\"font-bold text-lg text-foreground pr-8 tracking-tight\">¿Qué tecnologías utilizan?</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down w-5 h-5 text-foreground/50 flex-shrink-0 transform transition-transform\" aria-hidden=\"true\"><path d=\"m6 9 6 6 6-6\"></path></svg></button></div><div class=\"border borde