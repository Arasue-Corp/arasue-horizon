",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute inset-0 z-0\\\",\\\"children\\\":[[\\\"$\\\",\\\"img\\\",null,{\\\"src\\\":\\\"https://images.unsplash.com/photo-1497366216548-37526070297c?q=80\\u0026w=2069\\u0026auto=format\\u0026fit=crop\\\",\\\"alt\\\":\\\"Office\\\",\\\"className\\\":\\\"w-full h-full object-cover\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute inset-0 bg-black/30\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"relative z-10 text-white\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"inline-block px-4 py-2 rounded-full border border-white/20 backdrop-blur-md text-xs font-mono tracking-widest uppercase mb-8\\\",\\\"children\\\":\\\"Global Engineering\\\"}],[\\\"$\\\",\\\"h1\\\",null,{\\\"className\\\":\\\"text-5xl lg:text-7xl font-black tracking-tighter leading-[1.1] mb-6\\\",\\\"children\\\":\\\"Inicia tu Construcción\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xl text-white/80 font-medium max-w-md font-inter\\\",\\\"children\\\":\\\"Programa una sesión de descubrimiento con nuestros arquitectos senior.\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mt-16 grid grid-cols-2 gap-8 pt-8 border-t border-white/20\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs font-mono text-white/50 uppercase tracking-widest mb-1\\\",\\\"children\\\":\\\"Response Time\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-bold text-lg\\\",\\\"children\\\":\\\"Under 2 hours\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-xs font-mono text-white/50 uppercase tracking-widest mb-1\\\",\\\"children\\\":\\\"Direct Access\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"font-bold text-lg\\\",\\\"children\\\":\\\"Senior Architects\\\"}]]}]]}]]}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"lg:w-1/2 flex items-center justify-center p-6 py-24 lg:p-24 bg-background\\\",\\\"children\\\":[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"w-full max-w-xl\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"mb-12\\\",\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"text-3xl font-bold tracking-tight text-foreground mb-3\\\",\\\"children\\\":\\\"Project Details\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-foreground/60 font-inter\\\",\\\"children\\\":\\\"Fill out the form below and we will prepare a tailored engineering proposal for your company.\\\"}]]}],[\\\"$\\\",\\\"$L13\\\",null,{\\\"dict\\\":{\\\"nav\\\":\\\"$4:props:children:1:props:children:0:props:dict\\\",\\\"footer\\\":{\\\"about\\\":\\\"Somos un holding tecnológico dedicado a construir la infraestructura del futuro.\\\",\\\"links\\\":\\\"Enlaces Rápidos\\\",\\\"legal\\\":\\\"Legal\\\",\\\"privacy\\\":\\\"Política de Privacidad\\\",\\\"terms\\\":\\\"Términos de Servicio\\\",\\\"address\\\":\\\"Sede Global\\\",\\\"address_val\\\":\\\"123 Innovation Drive, Tech City, Global\\\",\\\"newsletter\\\":\\\"Suscríbete a nuestro Boletín\\\",\\\"newsletter_desc\\\":\\\"Recibe las últimas actualizaciones de Arasue Horizon.\\\",\\\"subscribe\\\":\\\"Suscribirse\\\",\\\"rights\\\":\\\"Todos los derechos reservados.\\\"},\\\"horizon\\\":{\\\"hero\\\":{\\\"title\\\":\\\"La perspectiva lo cambia todo.\\\",\\\"subtitle\\\":\\\"El mundo se mueve rápido, pero nosotros miramos más allá. Arasue Horizon es la matriz estratégica que conecta mercados, capitales e industrias globales con una visión clara y de largo alcance. No solo gestionamos el presente; diseñamos el mapa del mañana.\\\",\\\"cta\\\":\\\"Explora nuestro Ecosistema\\\",\\\"secondary_cta\\\":\\\"Lee nuestro Manifiesto\\\",\\\"explore_portfolio\\\":\\\"Explorar Portafolio\\\"},\\\"stats\\\":{\\\"companies\\\":\\\"Divisiones Activas\\\",\\\"projects\\\":\\\"Proyectos Globales\\\",\\\"valuation\\\":\\\"Millones en Valor Generado\\\",\\\"offices\\\":\\\"Oficinas Globales\\\"},\\\"vision\\\":{\\\"title\\\":\\\"Impulsando la Innovación\\\",\\\"p1\\\":\\\"En Arasue Horizon, creemos en el poder de la excelencia diversificada. Al incubar y escalar subsidiarias especializadas, creamos un ecosistema robusto donde la tecnología, los medios y los bienes convergen.\\\",\\\"p2\\\":\\\"Nuestro corporativo proporciona dirección estratégica, asignación de capital y recursos compartidos, permitiendo a nuestras divisiones enfocarse puramente en transformar sus respectivos mercados.\\\",\\\"link\\\":\\\"Conoce nuestra visión\\\"},\\\"subsidiaries\\\":{\\\"title\\\":\\\"Nuestro Ecosistema\\\",\\\"investors_link\\\":\\\"Ver Relación con Inversores\\\",\\\"forge\\\":{\\\"name\\\":\\\"Arasue Forge\\\",\\\"description\\\":\\\"Las grandes ideas no sirven de nada si se quedan en el aire. Arasue Forge es el estudio de desarrollo donde el software avanzado y la tecnología crítica cobran vida con precisión, fuerza y un rendimiento impecable. Construimos la infraestructura digital que define industrias.\\\",\\\"link\\\":\\\"Visitar Forge\\\",\\\"tag\\\":\\\"Ingeniería con carácter.\\\"},\\\"labs\\\":{\\\"name\\\":\\\"Arasue Labs\\\",\\\"description\\\":\\\"La verdadera excelencia no acepta atajos. Arasue Labs une el rigor de la ciencia con la pureza de la naturaleza, controlando la importación y logística de productos premium con una trazabilidad absoluta. Calidad inquebrantable, desde el origen hasta tus manos.\\\",\\\"link\\\":\\\"Visitar Labs\\\",\\\"tag\\\":\\\"Inalterable desde el origen.\\\"},\\\"media\\\":{\\\"name\\\":\\\"Arasue Media\\\",\\\"description\\\":\\\"En un mar de ruido constante, nosotros creamos profundidad. Arasue Media produce, edita y distribuye contenido de alta fidelidad que captura la atención y deja una marca real. Historias potentes respaldadas por una ejecución sofisticada.\\\",\\\"link\\\":\\\"Visitar Media\\\",\\\"tag\\\":\\\"Contenido con carácter.\\\"},\\\"protection\\\":{\\\"name\\\":\\\"Arasue Protection\\\",\\\"description\\\":\\\"El éxito real no se deja al azar. Arasue Protection blinda tu vida, tu salud y tu patrimonio con soluciones de aseguramiento de alto nivel y total certeza. Cuidamos de tu legado para que tú puedas enfocarte en seguir construyéndolo.\\\",\\\"link\\\":\\\"Visitar Protection\\\",\\\"tag\\\":\\\"Tranquilidad sin condiciones.\\\"}},\\\"global\\\":{\\\"title\\\":\\\"Presencia Global\\\",\\\"desc\\\":\\\"Operando de manera fluida en toda Norteamérica y el resto del mundo.\\\"},\\\"news\\\":{\\\"title\\\":\\\"Desde la Sala de Prensa\\\",\\\"link\\\":\\\"Ver Todas las Noticias\\\",\\\"tag\\\":\\\"Comunicado de Prensa\\\",\\\"article_title\\\":\\\"Arasue Horizon Anuncia Expansión Estratégica a Nuevos Mercados\\\",\\\"article_desc\\\":\\\"Lee sobre nuestras últimas adquisiciones estratégicas y cómo se alinean con nuestra visión para el próximo año fiscal.\\\"},\\\"leadership\\\":{\\\"title\\\":\\\"Liderazgo\\\",\\\"subtitle\\\":\\\"Guiados por operadores con un historial de retornos asimétricos.\\\",\\\"josue_role\\\":\\\"Director Ejecutivo\\\",\\\"josue_desc\\\":\\\"Arquitecto del ecosistema Arasue. Se enfoca en la asignación de capital y la visión a largo plazo.\\\",\\\"elena_role\\\":\\\"Directora de Forge\\\",\\\"elena_desc\\\":\\\"Ex ingeniera principal en importantes firmas tecnológicas. Lidera la ingeniería de productos y la escala de la plataforma.\\\",\\\"marcus_role\\\":\\\"Director de Media\\\",\\\"marcus_desc\\\":\\\"Estratega cultural que ha fabricado múltiples momentos virales globales.\\\"},\\\"investor_form\\\":{\\\"title\\\":\\\"Relaciones con Inversores\\\",\\\"subtitle\\\":\\\"Solicita acceso a nuestra tesis trimestral y divulgaciones financieras.\\\",\\\"name\\\":\\\"Nombre Completo\\\",\\\"firm\\\":\\\"Firma / Organización\\\",\\\"email\\\":\\\"Correo Corporativo\\\",\\\"type\\\":\\\"Tipo de Inversor\\\",\\\"type_vc\\\":\\\"Capital de Riesgo\\\",\\\"type_pe\\\":\\\"Capital Privado\\\",\\\"type_fo\\\":\\\"Family Office\\\",\\\"type_angel\\\":\\\"Ángel / Individual\\\",\\\"type_other\\\":\\\"Otro\\\",\\\"submit\\\":\\\"Solicitar Acceso\\\",\\\"submitting\\\":\\\"Solicitando...\\\",\\\"success\\\":\\\"Solicitud Recibida. Nuestro equipo revisará y responderá en breve.\\\"},\\\"philosophy\\\":{\\\"label\\\":\\\"Filosofía Operativa\\\",\\\"statement_1\\\":\\\"No seguimos tendencias.\\\",\\\"statement_2\\\":\\\"Construimos infraestructura.\\\",\\\"statement_3\\\":\\\"El capital es solo una herramienta. La excelencia operativa es el resultado.\\\"},\\\"global_impact\\\":{\\\"title\\\":\\\"Impacto Global\\\",\\\"subtitle\\\":\\\"Arquitectando sistemas a través de fronteras. Desde EE.UU. hacia Latinoamérica y el mundo.\\\",\\\"stat_1_val\\\":\\\"3\\\",\\\"stat_1_lbl\\\":\\\"Nodos Centrales\\\",\\\"stat_2_val\\\":\\\"24/7\\\",\\\"stat_2_lbl\\\":\\\"Operaciones\\\",\\\"stat_3_val\\\":\\\"$$0\\\",\\\"stat_3_lbl\\\":\\\"Fricción\\\"}},\\\"forge\\\":{\\\"hero\\\":{\\\"badge\\\":\\\"Ingeniería de Software Premium\\\",\\\"title\\\":\\\"Software Premium, Creado a la Perfección\\\",\\\"subtitle\\\":\\\"Transformamos tus ideas más audaces en productos digitales robustos, escalables y con un diseño impecable.\\\",\\\"cta\\\":\\\"Ver nuestros Servicios\\\",\\\"secondary_cta\\\":\\\"Ver Nuestro Trabajo\\\",\\\"cta_contact\\\":\\\"Agendar Llamada\\\"},\\\"ticker\\\":{\\\"trusted\\\":\\\"Impulsados por tecnologías líderes en la industria\\\"},\\\"services\\\":{\\\"title\\\":\\\"Nuestra Experiencia\\\",\\\"web_dev\\\":{\\\"title\\\":\\\"Desarrollo Web\\\",\\\"desc\\\":\\\"Experiencias web-scrolling a medida y de alto rendimiento.\\\"},\\\"brand_web\\\":{\\\"title\\\":\\\"Web de Marca Personal\\\",\\\"desc\\\":\\\"De Instagram a Web: Una landing page premium para tu marca.\\\"},\\\"meta_ads\\\":{\\\"title\\\":\\\"Auditoría Meta Ads\\\",\\\"desc\\\":\\\"Análisis profundo y optimización de tus campañas publicitarias.\\\"},\\\"seo_audit\\\":{\\\"title\\\":\\\"Auditoría SEO\\\",\\\"desc\\\":\\\"Auditoría técnica y de contenido para dominar los resultados de búsqueda.\\\"},\\\"automations\\\":{\\\"title\\\":\\\"Automatizaciones N8N\\\",\\\"desc\\\":\\\"Ahorra cientos de horas con automatizaciones de flujo de trabajo personalizadas.\\\"},\\\"pm\\\":{\\\"title\\\":\\\"Gestión de Proyectos\\\",\\\"desc\\\":\\\"Consultoría independiente y liderazgo de proyectos.\\\"}},\\\"work\\\":{\\\"title\\\":\\\"Trabajo Destacado\\\",\\\"subtitle\\\":\\\"Construimos arquitecturas escalables e interfaces hermosas que impulsan métricas de negocio reales.\\\",\\\"project1_category\\\":\\\"Plataforma Fintech\\\",\\\"project1_title\\\":\\\"Dashboard de Pagos Global\\\",\\\"project1_desc\\\":\\\"Una revisión completa de un dashboard financiero heredado, migrando a Next.js y Tailwind para mejorar los tiempos de carga en un 400% y la retención de usuarios en un 35%.\\\",\\\"project2_category\\\":\\\"App de E-Commerce\\\",\\\"project2_title\\\":\\\"Experiencia Retail Premium\\\",\\\"project2_desc\\\":\\\"Aplicación de comercio headless con sensación nativa utilizando React Native y la API de Storefront de Shopify. Aumentó las tasas de conversión móvil en más del 120%.\\\"},\\\"process\\\":{\\\"title\\\":\\\"Cómo Trabajamos\\\",\\\"subtitle\\\":\\\"No solo escribimos código; ingeniamos soluciones diseñadas para escalar desde el primer día.\\\",\\\"step1\\\":\\\"Descubrimiento y Estrategia\\\",\\\"step1_desc\\\":\\\"Analizamos las necesidades de tu negocio y elaboramos un plan técnico a medida.\\\",\\\"arch_title\\\":\\\"Arquitectura y Diseño\\\",\\\"arch_desc\\\":\\\"Diseñamos arquitecturas de sistemas escalables y una hermosa UI/UX que se alinea con tus objetivos de negocio.\\\",\\\"step2\\\":\\\"Desarrollo y Entrega\\\",\\\"step2_desc\\\":\\\"Construcción ágil, pruebas rigurosas y un lanzamiento impecable.\\\",\\\"step3\\\":\\\"Crecimiento y Soporte\\\",\\\"step3_desc\\\":\\\"Aseguramos que tu producto escale de manera eficiente.\\\"},\\\"pricing\\\":{\\\"title\\\":\\\"Precios SaaS Transparentes\\\",\\\"setup\\\":\\\"Inicial\\\",\\\"mo\\\":\\\"/mes\\\",\\\"one_time\\\":\\\"Pago Único\\\",\\\"retainer\\\":\\\"Mensualidad\\\",\\\"features\\\":\\\"Incluye hosting, actualizaciones y soporte prioritario.\\\"},\\\"testimonials\\\":{\\\"text1\\\":\\\"Arasue Forge transformó toda nuestra infraestructura digital. Su arquitectura nos permitió escalar de 10k a 500k usuarios activos mensuales sin un solo contratiempo.\\\",\\\"author1\\\":\\\"Sarah Jenkins\\\",\\\"role1\\\":\\\"CTO, Vertex Analytics\\\",\\\"text2\\\":\\\"La pura velocidad y calidad de su desarrollo en React no tiene igual. No solo construyen apps, construyen productos que la gente ama usar.\\\",\\\"author2\\\":\\\"David Chen\\\",\\\"role2\\\":\\\"Fundador, Elevate\\\"},\\\"cta\\\":{\\\"title\\\":\\\"¿Listo para construir?\\\",\\\"subtitle\\\":\\\"Deja de comprometer la calidad de tu ingeniería. Asóciate con nosotros y escala tus productos digitales hoy.\\\",\\\"note\\\":\\\"Respuesta en 24 horas. Sin compromisos.\\\"},\\\"faq\\\":{\\\"title\\\":\\\"Preguntas Frecuentes\\\",\\\"q1\\\":\\\"¿Ofrecen desarrollo a medida fuera de estos planes?\\\",\\\"a1\\\":\\\"Sí, manejamos aplicaciones personalizadas a nivel empresarial. Contáctanos para una cotización a medida.\\\",\\\"q2\\\":\\\"¿Qué tecnologías utilizan?\\\",\\\"a2\\\":\\\"Nos especializamos en el ecosistema React (Next.js), Node.js y arquitecturas nativas de la nube.\\\",\\\"q3\\\":\\\"¿Cómo funciona el modelo web SaaS?\\\",\\\"a3\\\":\\\"En lugar de un costo inicial masivo, pagas una pequeña tarifa de instalación y una suscripción mensual que cubre alojamiento, mantenimiento y actualizaciones menores para siempre.\\\"},\\\"services_page\\\":{\\\"title\\\":\\\"Diseñados para Dominar\\\",\\\"subtitle\\\":\\\"No solo creamos páginas web. Construimos sistemas escalables que dominan tu mercado.\\\",\\\"scarcity\\\":\\\"Debido a nuestra alta exigencia de calidad, solo aceptamos 3 nuevos clientes por trimestre.\\\"},\\\"portfolio_page\\\":{\\\"title\\\":\\\"Nuestro Trabajo\\\",\\\"subtitle\\\":\\\"Casos de estudio de productos digitales escalables.\\\"},\\\"pricing_page\\\":{\\\"title\\\":\\\"Precios Transparentes y Escalables\\\",\\\"subtitle\\\":\\\"Sin costos ocultos. Infraestructura premium en modelos predecibles.\\\",\\\"anchoring_text\\\":\\\"Mientras las agencias tradicionales cobran más de $50k USD por adelantado, nuestro modelo SaaS garantiza cero deuda técnica por una fracción del costo.\\\"},\\\"contact_page\\\":{\\\"title\\\":\\\"Inicia tu Construcción\\\",\\\"subtitle\\\":\\\"Programa una sesión de descubrimiento con nuestros arquitectos senior.\\\"},\\\"process_section\\\":{\\\"title\\\":\\\"Cómo Construimos\\\",\\\"subtitle\\\":\\\"Un enfoque inflexible hacia la ingeniería.\\\",\\\"steps\\\":[{\\\"title\\\":\\\"Descubrimiento de Arquitectura\\\",\\\"desc\\\":\\\"Mapeamos los requisitos técnicos precisos, modelos de datos y necesidades de infraestructura.\\\"},{\\\"title\\\":\\\"Diseño de Sistemas\\\",\\\"desc\\\":\\\"Creación de esquemas de bases de datos escalables y wireframes de alta fidelidad que convierten.\\\"},{\\\"title\\\":\\\"Sprints de Ingeniería\\\",\\\"desc\\\":\\\"Desarrollo rápido y ágil utilizando Next.js y arquitecturas sólidas en la nube.\\\"},{\\\"title\\\":\\\"Despliegue y Escala\\\",\\\"desc\\\":\\\"Despliegue sin tiempo de inactividad, QA y optimización continua de rendimiento.\\\"}]},\\\"estimator_section\\\":{\\\"title\\\":\\\"Estimador de Proyectos\\\",\\\"subtitle\\\":\\\"Obtén una línea base inmediata para tu software a medida o transformación digital.\\\",\\\"complexity\\\":\\\"Complejidad del Alcance\\\",\\\"timeline\\\":\\\"Urgencia del Cronograma\\\",\\\"min\\\":\\\"MVP / Web App\\\",\\\"max\\\":\\\"Ecosistema Empresarial\\\",\\\"options\\\":[{\\\"id\\\":\\\"relaxed\\\",\\\"label\\\":\\\"Estándar (3-4 Meses)\\\"},{\\\"id\\\":\\\"rush\\\",\\\"label\\\":\\\"Urgente (8-10 Semanas)\\\"}],\\\"total\\\":\\\"Inversión Estimada\\\",\\\"note\\\":\\\"*Estimación basada en disponibilidad actual. El alcance final requiere una sesión de descubrimiento.\\\",\\\"cta\\\":\\\"Solicitar Propuesta Formal\\\",\\\"submitting\\\":\\\"Solicitando...\\\",\\\"success\\\":\\\"Propuesta solicitada. Te contactaremos pronto.\\\",\\\"emailPrompt\\\":\\\"Ingresa tu correo laboral para recibir la propuesta:\\\"}},\\\"media\\\":{\\\"hero\\\":{\\\"title\\\":\\\"Dando Forma a la Cultura Digital\\\",\\\"subtitle\\\":\\\"Arasue Media es una potencia en la creación de contenido, streams y narrativa digital.\\\",\\\"cta\\\":\\\"Ver lo Más Reciente\\\",\\\"cta_contact\\\":\\\"Trabaja con Nosotros\\\"},\\\"services\\\":{\\\"title\\\":\\\"Nuestras Capacidades\\\",\\\"content\\\":\\\"Producción de Contenido\\\",\\\"streams\\\":\\\"Transmisiones en Vivo\\\",\\\"branding\\\":\\\"Branding Digital\\\"},\\\"work_page\\\":{\\\"title\\\":\\\"Campañas Destacadas\\\",\\\"subtitle\\\":\\\"Contenido de alto voltaje que moldea la cultura digital.\\\"},\\\"creators_page\\\":{\\\"title\\\":\\\"Nuestro Talento\\\",\\\"subtitle\\\":\\\"Nuestra red exclusiva de talento digital y productores.\\\"},\\\"contact_page\\\":{\\\"title\\\":\\\"Colabora con Nosotros\\\",\\\"subtitle\\\":\\\"¿Listo para volverte viral? Hablemos de estrategia.\\\"}},\\\"labs\\\":{\\\"hero\\\":{\\\"title\\\":\\\"La Naturaleza se Une a la Ciencia\\\",\\\"subtitle\\\":\\\"Productos orgánicos premium, obtenidos de manera sustentable y creados meticulosamente.\\\",\\\"cta\\\":\\\"Ver Colección\\\"},\\\"products\\\":{\\\"title\\\":\\\"Nuestra Colección\\\",\\\"honey\\\":{\\\"title\\\":\\\"Miel Cruda Orgánica\\\",\\\"desc\\\":\\\"Miel 100% pura y sin pasteurizar obtenida directamente de nuestras reservas.\\\"},\\\"wellness\\\":{\\\"title\\\":\\\"Extractos de Bienestar\\\",\\\"desc\\\":\\\"Potentes tinturas orgánicas y suplementos para la salud.\\\"}},\\\"shop_page\\\":{\\\"title\\\":\\\"La Botica\\\",\\\"subtitle\\\":\\\"Cosechas orgánicas de lote limitado. Prueba la naturaleza intacta.\\\"},\\\"story_page\\\":{\\\"title\\\":\\\"Nuestros Orígenes\\\",\\\"subtitle\\\":\\\"De bosques profundos a extractos premium. El viaje de Arasue Labs.\\\"},\\\"contact_page\\\":{\\\"title\\\":\\\"Mayoreo y Soporte\\\",\\\"subtitle\\\":\\\"Contáctanos para pedidos por volumen y asociaciones premium.\\\"}},\\\"corporate\\\":{\\\"about\\\":{\\\"title\\\":\\\"Nuestra Misión\\\",\\\"content\\\":\\\"Arasue Horizon se dedica a construir ecosistemas escalables de software, medios y sustentabilidad.\\\"},\\\"investors\\\":{\\\"title\\\":\\\"Relación con Inversores\\\",\\\"content\\\":\\\"Accede a nuestros últimos reportes financieros, documentos de gobierno corporativo e información para accionistas.\\\"},\\\"newsroom\\\":{\\\"title\\\":\\\"Sala de Prensa\\\",\\\"content\\\":\\\"Últimas noticias, comunicados y recursos de medios de Arasue Horizon.\\\"},\\\"contact\\\":{\\\"title\\\":\\\"Cuartel General Global\\\",\\\"content\\\":\\\"Asóciate con Arasue Horizon. Líneas directas a nuestros equipos de inversión y RP.\\\",\\\"form\\\":{\\\"name_lbl\\\":\\\"Nombre Completo\\\",\\\"email_lbl\\\":\\\"Correo Corporativo\\\",\\\"subject_lbl\\\":\\\"Asunto\\\",\\\"message_lbl\\\":\\\"Mensaje\\\",\\\"btn_submit\\\":\\\"Enviar Mensaje\\\",\\\"btn_submitting\\\":\\\"Transmitiendo...\\\",\\\"success_title\\\":\\\"Transmisión Recibida\\\",\\\"success_desc\\\":\\\"Nuestro equipo de operaciones revisará tu consulta y responderá en menos de 24 horas.\\\",\\\"success_btn\\\":\\\"Enviar Otro Mensaje\\\"},\\\"info\\\":{\\\"hq_title\\\":\\\"Nodo Principal\\\",\\\"press\\\":\\\"Consultas de Prensa\\\",\\\"investors\\\":\\\"Relaciones con Inversores\\\"}}}}}]]}]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"b:[[\\\"$\\\",\\\"meta\\\",\\\"0\\\",{\\\"charSet\\\":\\\"utf-8\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"viewport\\\",\\\"content\\\":\\\"width=device-width, initia