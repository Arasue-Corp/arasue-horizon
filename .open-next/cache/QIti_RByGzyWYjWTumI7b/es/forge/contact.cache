le__dsR-KG__variable\",\"children\":[[\"$\",\"$L11\",null,{\"dict\":{\"horizon\":\"Arasue Horizon\",\"forge\":\"Arasue Forge\",\"workshop\":\"Workshop\",\"language\":\"Idioma\",\"divisions\":\"Divisiones\",\"currency_detected\":\"Moneda\",\"holding_menu\":{\"title\":\"El Corporativo\",\"overview\":\"Visión General\",\"overview_desc\":\"Conoce nuestra misión y visión.\",\"investors\":\"Relación con Inversores\",\"investors_desc\":\"Reportes financieros y noticias.\",\"careers\":\"Carreras\",\"careers_desc\":\"Únete a nuestro equipo global.\",\"newsroom\":\"Sala de Prensa\",\"newsroom_desc\":\"Prensa y Actualizaciones\",\"contact\":\"Sede Global\",\"contact_desc\":\"Consultas globales\"},\"subsidiaries_menu\":{\"forge_desc\":\"Productos digitales y SaaS\",\"media_desc\":\"Contenido y Streaming\",\"labs_desc\":\"Bienes orgánicos premium\"},\"services_menu\":{\"growth\":\"Crecimiento y Anuncios\",\"growth_desc\":\"Estrategias SEO y Meta Ads\"},\"forge_menu\":{\"title\":\"Agencia de Software\",\"services\":\"Servicios\",\"services_desc\":\"Desarrollo de software premium.\",\"portfolio\":\"Portafolio\",\"portfolio_desc\":\"Mira nuestro trabajo reciente.\",\"contact\":\"Contáctanos\",\"contact_desc\":\"Inicia tu próximo proyecto.\"},\"media_menu\":{\"title\":\"Producción Multimedia\"},\"labs_menu\":{\"title\":\"Productos Orgánicos\"}},\"lang\":\"es\"}],[\"$\",\"main\",null,{\"className\":\"flex-1\",\"children\":[\"$\",\"$L2\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L3\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]}],[\"$\",\"footer\",null,{\"className\":\"mt-20 border-t border-foreground/10 bg-background pt-16 pb-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"container mx-auto px-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"