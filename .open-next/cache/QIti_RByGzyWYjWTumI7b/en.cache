crop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1573496359142-b8d87734a5a2%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><h3 class=\"text-2xl font-bold mb-2\">Elena M.</h3><div class=\"text-sm font-bold uppercase tracking-widest text-neutral-400 mb-4\">Head of Forge</div><p class=\"text-neutral-500 leading-relaxed\">Former staff engineer at major tech firms. Leads product engineering and platform scale.</p></div><div class=\"group\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"aspect-[4/5] rounded-[2rem] overflow-hidden mb-8 bg-neutral-100 relative\"><img alt=\"Marcus T.\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover grayscale group-hover:grayscale-0 transition-all duration-700\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"(max-width: 768px) 100vw, 33vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=256&amp;q=75 256w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=384&amp;q=75 384w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1507003211169-0a1dd7228f2d%3Fq%3D80%26w%3D600%26auto%3Dformat%26fit%3Dcrop&amp;w=3840&amp;q=75\"/></div><h3 class=\"text-2xl font-bold mb-2\">Marcus T.</h3><div class=\"text-sm font-bold uppercase tracking-widest text-neutral-400 mb-4\">Head of Media</div><p class=\"text-neutral-500 leading-relaxed\">Cultural strategist who has manufactured multiple global viral moments.</p></div></div></div></section><section id=\"portfolio\" class=\"py-32 px-6 bg-[#F2F2F2]\"><div class=\"max-w-7xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-20\"><h2 class=\"text-5xl md:text-7xl font-playfair tracking-tight mb-6 text-[#162D59]\">The Arasue Ecosystem</h2><p class=\"text-xl text-[#162D59]/60 max-w-2xl mx-auto font-inter\">Five interconnected divisions driving cultural and commercial momentum.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\"><a href=\"/forge\"><div class=\"group relative h-[320px] rounded-[2rem] overflow-hidden bg-[#162D59]/[0.02] border border-[#162D59]/10 p-10 flex flex-col justify-between hover:border-[#162D59]/20 hover:bg-white/40 backdrop-blur-[15px] transition-all duration-500 shadow-[0_8px_32px_0_rgba(22,45,89,0.05)]\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[#0511F2] to-[#05F2DB] opacity-10 group-hover:opacity-20 rounded-full blur-[60px] transition-opacity duration-700 -mr-20 -mt-20\"></div><div class=\"relative z-10\"><h3 class=\"text-3xl font-playfair font-bold mb-4 text-[#162D59]\">Arasue Forge</h3><p class=\"text-[#162D59]/70 text-lg leading-relaxed max-w-md font-inter\">Great ideas mean nothing if they stay in the air. Arasue Forge is the development studio where advanced software and critical tech come to life with precision, power, and flawless performance.</p></div><div class=\"flex items-center text-sm font-bold uppercase tracking-widest text-[#162D59]/50 group-hover:text-[#162D59] transition-colors relative z-10\">Explore Division<span class=\"ml-2 transform group-hover:translate-x-2 transition-transform\">→</span></div><div class=\"absolute inset-0 border-2 border-transparent group-hover:border-[#A65E44]/20 rounded-[2rem] pointer-events-none transition-colors duration-500\"></div></div></a><a href=\"/media\"><div class=\"group relative h-[320px] rounded-[2rem] overflow-hidden bg-[#162D59]/[0.02] border border-[#162D59]/10 p-10 flex flex-col justify-between hover:border-[#162D59]/20 hover:bg-white/40 backdrop-blur-[15px] transition-all duration-500 shadow-[0_8px_32px_0_rgba(22,45,89,0.05)]\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[#F28F6B] to-[#A65E44] opacity-10 group-hover:opacity-20 rounded-full blur-[60px] transition-opacity duration-700 -mr-20 -mt-20\"></div><div class=\"relative z-10\"><h3 class=\"text-3xl font-playfair font-bold mb-4 text-[#162D59]\">Arasue Media</h3><p class=\"text-[#162D59]/70 text-lg leading-relaxed max-w-md font-inter\">In a sea of constant noise, we create depth. Arasue Media produces, publishes, and distributes high-fidelity content that captures attention and leaves a real mark.</p></div><div class=\"flex items-center text-sm font-bold uppercase tracking-widest text-[#162D59]/50 group-hover:text-[#162D59] transition-colors relative z-10\">Explore Division<span class=\"ml-2 transform group-hover:translate-x-2 transition-transform\">→</span></div><div class=\"absolute inset-0 border-2 border-transparent group-hover:border-[#A65E44]/20 rounded-[2rem] pointer-events-none transition-colors duration-500\"></div></div></a><a href=\"/labs\"><div class=\"group relative h-[320px] rounded-[2rem] overflow-hidden bg-[#162D59]/[0.02] border border-[#162D59]/10 p-10 flex flex-col justify-between hover:border-[#162D59]/20 hover:bg-white/40 backdrop-blur-[15px] transition-all duration-500 shadow-[0_8px_32px_0_rgba(22,45,89,0.05)]\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[#1a2e1a] to-emerald-800 opacity-10 group-hover:opacity-20 rounded-full blur-[60px] transition-opacity duration-700 -mr-20 -mt-20\"></div><div class=\"relative z-10\"><h3 class=\"text-3xl font-playfair font-bold mb-4 text-[#162D59]\">Arasue Labs</h3><p class=\"text-[#162D59]/70 text-lg leading-relaxed max-w-md font-inter\">True excellence accepts no shortcuts. Arasue Labs bridges scientific rigor with nature&#x27;s purity, managing the import and logistics of premium products with absolute traceability.</p></div><div class=\"flex items-center text-sm font-bold uppercase tracking-widest text-[#162D59]/50 group-hover:text-[#162D59] transition-colors relative z-10\">Explore Division<span class=\"ml-2 transform group-hover:translate-x-2 transition-transform\">→</span></div><div class=\"absolute inset-0 border-2 border-transparent group-hover:border-[#A65E44]/20 rounded-[2rem] pointer-events-none transition-colors duration-500\"></div></div></a><a href=\"/protection\"><div class=\"group relative h-[320px] rounded-[2rem] overflow-hidden bg-[#162D59]/[0.02] border border-[#162D59]/10 p-10 flex flex-col justify-between hover:border-[#162D59]/20 hover:bg-white/40 backdrop-blur-[15px] transition-all duration-500 shadow-[0_8px_32px_0_rgba(22,45,89,0.05)]\" style=\"opacity:0;transform:translateY(30px)\"><div class=\"absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-[#162D59] to-slate-500 opacity-10 group-hover:opacity-20 rounded-full blur-[60px] transition-opacity duration-700 -mr-20 -mt-20\"></div><div class=\"relative z-10\"><h3 class=\"text-3xl font-playfair font-bold mb-4 text-[#162D59]\">Arasue Protection</h3><p class=\"text-[#162D59]/70 text-lg leading-relaxed max-w-md font-inter\">Real success is never left to chance. Arasue Protection shields your life, health, and wealth with high-tier insurance solutions and absolute certainty.</p></div><div class=\"flex items-center text-sm font-bold uppercase tracking-widest text-[#162D59]/50 group-hover:text-[#162D59] transition-colors relative z-10\">Explore Division<span class=\"ml-2 transform group-hover:translate-x-2 transition-transform\">→</span></div><div class=\"absolute inset-0 border-2 border-transparent group-hover:border-[#A65E44]/20 rounded-[2rem] pointer-events-none transition-colors duration-500\"></div></div></a></div></div></section><section class=\"relative py-32 overflow-hidden bg-[#0B0F19]\"><div class=\"absolute inset-0 z-0 opacity-20 pointer-events-none\"><img alt=\"Global Network\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill